<?xml version="1.0" encoding="utf-8"?>
<!--
  Piper robot description (with gripper).

  Adapted from piper_ros/piper_description/urdf/piper_description.urdf
  with mesh paths rewritten to package://genie_sim_robot_model/robots/agilex/piper/meshes/.

  Original: SolidWorks URDF Exporter
  6-DOF revolute arm + parallel prismatic gripper (joint7 + joint8)

  Conventions (aligned with arx_x5, single-arm flavor):
    - Links/joints renamed from link1..6 / joint1..6 to arm_link1..6 /
      arm_joint1..6 to match the arx_x5 family.
    - Gripper link/joint pairs use active/passive naming: the master DOF
      is gripper_active_joint (formerly joint7) and the mimic DOF is
      gripper_passive_joint (formerly joint8).
    - Mesh files renamed accordingly (link*.STL -> arm_link*.STL,
      link7.STL -> gripper_active_link.STL, link8.STL ->
      gripper_passive_link.STL).
    - After arm_link6: arm_end_link (massless placeholder, identity-
      fixed) so the wrist→gripper interface has a stable named anchor,
      matching arx_x5.
    - gripper_base_link retains its real mesh + inertial (a substantial
      shroud in piper, unlike the massless placeholder used by arx_x5).
-->
<robot name="piper"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_dir" value="package://genie_sim_robot_model/robots/agilex/piper/meshes" />

  <!-- base_link is intentionally an empty link so it can serve as the KDL
       root: kdl_parser rejects a root link that carries inertia. The
       visual / collision / inertial payload is moved to base_link_inertia,
       a child of base_link via an identity-transform fixed joint. The
       kinematic chain (arm_joint1 ...) still hangs off base_link, so no
       downstream link/joint names change.

       The 1mm guide-sphere <visual> below flips the Isaac Sim 6.0
       URDF→USD converter's is_ghost_link check to False so it authors
       body0=parent_link on every joint. See
       genie_sim_robot_model/AGENTS.md → "Non-ghost root link pattern". -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.001"/></geometry>
    </visual>
  </link>
  <link name="base_link_inertia">
    <inertial>
      <origin xyz="-0.00473641164191482 2.56829134630247E-05 0.041451518036016" rpy="0 0 0" />
      <mass value="1.02" />
      <inertia ixx="0.00267433" ixy="-0.00000073" ixz="-0.00017389" iyy="0.00282612" iyz="0.0000004" izz="0.00089624" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/base_link.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/base_link.STL" /></geometry>
    </collision>
  </link>
  <joint name="base_link-base_link_inertia" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="base_link_inertia" />
  </joint>

  <link name="arm_link1">
    <inertial>
      <origin xyz="0.00032 -0.00041 -0.00348" rpy="0 0 0" />
      <mass value="0.71" />
      <inertia ixx="0.00050027" ixy="0.00000078" ixz="0.00000626" iyy="0.00040879" iyz="0.00000462" izz="0.00045802" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link1.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link1.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint1" type="revolute">
    <origin xyz="0 0 0.123" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="arm_link1" />
    <axis xyz="0 0 1" />
    <limit lower="-2.618" upper="2.618" effort="100" velocity="5" />
  </joint>

  <link name="arm_link2">
    <inertial>
      <origin xyz="0.21852 -0.00861 0.00126" rpy="0 0 0" />
      <mass value="1.16" />
      <inertia ixx="0.00111915" ixy="0.00182916" ixz="0.00019233" iyy="0.06763251" iyz="0.00000767" izz="0.067559" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link2.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link2.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint2" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 -0.1359 -3.1416" />
    <parent link="arm_link1" />
    <child link="arm_link2" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="3.14" effort="100" velocity="5" />
  </joint>

  <link name="arm_link3">
    <inertial>
      <origin xyz="-0.01999 -0.14808 -0.00053" rpy="0 0 0" />
      <mass value="0.5" />
      <inertia ixx="0.01347608" ixy="0.00161034" ixz="0.00000066" iyy="0.00046377" iyz="0.00000162" izz="0.01363321" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link3.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link3.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint3" type="revolute">
    <origin xyz="0.28503 0 0" rpy="0 0 -1.7939" />
    <parent link="arm_link2" />
    <child link="arm_link3" />
    <axis xyz="0 0 1" />
    <limit lower="-2.967" upper="0" effort="100" velocity="5" />
  </joint>

  <link name="arm_link4">
    <inertial>
      <origin xyz="0.00013 -0.00076 -0.00394" rpy="0 0 0" />
      <mass value="0.38" />
      <inertia ixx="0.00017844" ixy="0.00000062" ixz="0.00000067" iyy="0.00018914" iyz="0.00000408" izz="0.00014613" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link4.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link4.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint4" type="revolute">
    <origin xyz="-0.021984 -0.25075 0" rpy="1.5708 0 0" />
    <parent link="arm_link3" />
    <child link="arm_link4" />
    <axis xyz="0 0 1" />
    <limit lower="-1.745" upper="1.745" effort="100" velocity="5" />
  </joint>

  <link name="arm_link5">
    <inertial>
      <origin xyz="0.00018 -0.06104 -0.00227" rpy="0 0 0" />
      <mass value="0.383" />
      <inertia ixx="0.00172318" ixy="0.00000259" ixz="0.00000010" iyy="0.00017936" iyz="0.00000990" izz="0.00171172" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link5.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link5.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint5" type="revolute">
    <origin xyz="0 0 0" rpy="-1.5708 0 0" />
    <parent link="arm_link4" />
    <child link="arm_link5" />
    <axis xyz="0 0 1" />
    <limit lower="-1.22" upper="1.22" effort="100" velocity="5" />
  </joint>

  <link name="arm_link6">
    <inertial>
      <origin xyz="-0.00003 0.00006 0.04618" rpy="0 0 0" />
      <mass value="0.007" />
      <inertia ixx="0.00152112" ixy="0.00000202" ixz="0.00000261" iyy="0.00138626" iyz="0.00000002" izz="0.00031152" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link6.STL" /></geometry>
      <material name=""><color rgba="0.89804 0.91765 0.92941 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link6.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint6" type="revolute">
    <origin xyz="8.8259E-05 -0.091 0" rpy="1.5708 0 0" />
    <parent link="arm_link5" />
    <child link="arm_link6" />
    <axis xyz="0 0 1" />
    <limit lower="-2.0944" upper="2.0944" effort="100" velocity="3" />
  </joint>

  <link name="arm_end_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1e-6" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="arm_end_fixed" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="arm_link6" />
    <child link="arm_end_link" />
  </joint>

  <link name="gripper_base_link">
    <inertial>
      <origin xyz="-0.000183807162235591 8.05033155577911E-05 0.0321436689908876" rpy="0 0 0" />
      <mass value="0.45" />
      <inertia ixx="0.00092934" ixy="0.00000034" ixz="-0.00000738" iyy="0.00071447" iyz="0.00000005" izz="0.00039442" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_base.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_base.STL" /></geometry>
    </collision>
  </link>
  <joint name="gripper_base_fixed" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="arm_end_link" />
    <child link="gripper_base_link" />
  </joint>

  <link name="gripper_active_link">
    <inertial>
      <origin xyz="0.00065123185041968 -0.0491929869131989 0.00972258769184025" rpy="0 0 0" />
      <mass value="0.025" />
      <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021" iyy="0.00000781" iyz="-0.00001372" izz="0.0000747" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_active_link.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_active_link.STL" /></geometry>
    </collision>
  </link>
  <joint name="gripper_active_joint" type="prismatic">
    <origin xyz="0 0 0.1358" rpy="1.5708 0 0" />
    <parent link="gripper_base_link" />
    <child link="gripper_active_link" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.035" effort="10" velocity="1" />
  </joint>

  <link name="gripper_passive_link">
    <inertial>
      <origin xyz="0.000651231850419722 -0.0491929869131991 0.00972258769184024" rpy="0 0 0" />
      <mass value="0.025" />
      <inertia ixx="0.00007371" ixy="-0.00000113" ixz="0.00000021" iyy="0.00000781" iyz="-0.00001372" izz="0.0000747" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_passive_link.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_passive_link.STL" /></geometry>
    </collision>
  </link>
  <joint name="gripper_passive_joint" type="prismatic">
    <origin xyz="0 0 0.1358" rpy="1.5708 0 -3.1416" />
    <parent link="gripper_base_link" />
    <child link="gripper_passive_link" />
    <axis xyz="0 0 -1" />
    <limit lower="-0.035" upper="0" effort="10" velocity="1" />
    <mimic joint="gripper_active_joint" multiplier="-1" offset="0" />
  </joint>

</robot>
