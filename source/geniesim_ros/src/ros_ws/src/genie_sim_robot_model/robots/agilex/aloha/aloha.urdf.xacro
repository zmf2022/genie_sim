<?xml version="1.0"?>
<robot name="agilex_aloha"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_dir" value="package://genie_sim_robot_model/robots/agilex/aloha/meshes" />

  <!-- PBR material tuning.  The visual meshes (.dae) carry their own
       embedded materials (albedo / textures).  DAE roughness/metallic
       round-trips poorly and the Isaac Sim 6.0 URDF→USD converter doesn't
       read them, so every embedded material lands at the converter default
       (roughness=0.5, metallic=0.0).  Each <visual> below carries an inline
       <material_override> that patches the metallic/roughness of that
       visual's embedded material(s) in place — albedo/textures are kept.
       Authoring it inside the <visual> auto-scopes it to exactly that
       mesh (a link with several visuals just gets one override per visual,
       no attributes needed). urdfdom / robot_state_publisher / MoveIt /
       Isaac's converter all ignore the element; assemble_robot.py strips it
       from the URDF it feeds the converter and applies it post-conversion.
       See genie_sim_engine/AGENTS.md → "<material_override>". -->

  <xacro:macro name="aloha_arm"
    params="prefix parent mount_xyz mount_rpy gripper_mesh_subdir gripper7_xyz gripper8_xyz gripper7_rpy:='1.5708 0 1.5708' gripper8_rpy:='-1.5708 0 1.5708'">

    <link name="arm_${prefix}_base_link">
      <inertial>
        <origin xyz="-0.00979274765955341 1.82905827587138E-06 0.0410100126360189" rpy="0 0 0" />
        <mass value="0.162548567403693" />
        <inertia ixx="0.000226596924525071" ixy="-7.33972270153965E-08" ixz="2.13249977802622E-06"
          iyy="0.000269444772561524" iyz="8.15169009611054E-09" izz="0.000222318258878636" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/base_link.dae" />
        </geometry>
        <material_override><roughness>0.45</roughness><metallic>0.85</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_base_joint" type="fixed">
      <origin xyz="${mount_xyz}" rpy="${mount_rpy}" />
      <parent link="${parent}" />
      <child link="arm_${prefix}_base_link" />
    </joint>

    <link name="arm_${prefix}_link1">
      <inertial>
        <origin xyz="0.00131676031927024 0.000310288842008612 -0.00922874512303437" rpy="0 0 0" />
        <mass value="0.0978679932242825" />
        <inertia ixx="7.76684558296782E-05" ixy="1.09084650459924E-07" ixz="-1.9748053243241E-06"
          iyy="9.24967780161547E-05" iyz="9.91284646834582E-07" izz="8.24589062407807E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/link1.dae" />
        </geometry>
        <material_override><roughness>0.45</roughness><metallic>0.85</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_joint1" type="revolute">
      <origin xyz="0 0 0.123" rpy="0 0 -1.5708" />
      <parent link="arm_${prefix}_base_link" />
      <child link="arm_${prefix}_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-2.618" upper="2.618" effort="100" velocity="3" />
    </joint>

    <link name="arm_${prefix}_link2">
      <inertial>
        <origin xyz="0.148793602378802 -0.00242026983944119 0.00175154638467948" rpy="0 0 0" />
        <mass value="0.290888938633388" />
        <inertia ixx="0.000148959640166183" ixy="-7.37750384371657E-05" ixz="-9.68688405196236E-07"
          iyy="0.00172800946632652" iyz="-1.09692225564224E-06" izz="0.0017754628344594" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/link2.dae" />
        </geometry>
        <material_override><roughness>0.45</roughness><metallic>0.85</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_joint2" type="revolute">
      <origin xyz="0 0 0" rpy="1.5708 0 -1.5708" />
      <parent link="arm_${prefix}_link1" />
      <child link="arm_${prefix}_link2" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="3.14" effort="100" velocity="3" />
    </joint>

    <link name="arm_${prefix}_link3">
      <inertial>
        <origin xyz="-0.0996835215213704 0.0349477226691318 0.000508025815507312" rpy="0 0 0" />
        <mass value="0.290847697793211" />
        <inertia ixx="0.000107879011637167" ixy="2.92669521203626E-05" ixz="6.825922326238E-07"
          iyy="0.000214751671792086" iyz="-7.78469047878196E-07" izz="0.000241923439340319" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/link3.dae" />
        </geometry>
        <material_override><roughness>0.45</roughness><metallic>0.85</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_joint3" type="revolute">
      <origin xyz="0.28358 0.028726 0" rpy="0 0 0.10095" />
      <parent link="arm_${prefix}_link2" />
      <child link="arm_${prefix}_link3" />
      <axis xyz="0 0 1" />
      <limit lower="-2.697" upper="0" effort="100" velocity="3" />
    </joint>

    <link name="arm_${prefix}_link4">
      <inertial>
        <origin xyz="0.000276464622387979 -0.00102803669324875 -0.00472830700561663" rpy="0 0 0" />
        <mass value="0.127087348341362" />
        <inertia ixx="3.82011730423416E-05" ixy="-4.92358350897513E-08" ixz="4.89589432973119E-08"
          iyy="4.87048555222578E-05" iyz="6.70802942500512E-08" izz="4.10592077565559E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/link4.dae" />
        </geometry>
        <material_override><roughness>0.45</roughness><metallic>0.85</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_joint4" type="revolute">
      <origin xyz="-0.24221 0.068514 0" rpy="-1.5708 0 1.3826" />
      <parent link="arm_${prefix}_link3" />
      <child link="arm_${prefix}_link4" />
      <axis xyz="0 0 1" />
      <limit lower="-1.832" upper="1.832" effort="100" velocity="3" />
    </joint>

    <link name="arm_${prefix}_link5">
      <inertial>
        <origin xyz="8.82262433516967E-05 0.0566829014808256 -0.00196119720482461" rpy="0 0 0" />
        <mass value="0.144711242639457" />
        <inertia ixx="4.39644313662493E-05" ixy="-3.59259686444846E-08" ixz="-1.89747741386183E-08"
          iyy="5.63173920951307E-05" iyz="-2.1540716689785E-07" izz="4.88713664675268E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/link5.dae" />
        </geometry>
        <material_override><roughness>0.45</roughness><metallic>0.85</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_joint5" type="revolute">
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <parent link="arm_${prefix}_link4" />
      <child link="arm_${prefix}_link5" />
      <axis xyz="0 0 1" />
      <limit lower="-1.22" upper="1.22" effort="100" velocity="3" />
    </joint>

    <link name="arm_${prefix}_link6">
      <inertial>
        <origin xyz="0.00103120214523473 0.0121761387587524 0.0315480874960164" rpy="0 0 0" />
        <mass value="0.195187143240719" />
        <inertia ixx="6.43790256535539E-05" ixy="-1.2366166157046E-06" ixz="1.97664606328472E-07"
          iyy="0.000126146396374301" iyz="2.41157078516408E-06" izz="0.000154087076816444" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/${gripper_mesh_subdir}/link6.dae" />
        </geometry>
        <material_override><roughness>0.05</roughness><metallic>1.0</metallic></material_override>
      </visual>
    </link>
    <joint name="arm_${prefix}_joint6" type="revolute">
      <origin xyz="0 0.091 0.0014165" rpy="-1.5708 -1.5708 0" />
      <parent link="arm_${prefix}_link5" />
      <child link="arm_${prefix}_link6" />
      <axis xyz="0 0 1" />
      <limit lower="-3.14" upper="3.14" effort="100" velocity="3" />
    </joint>

    <link name="arm_${prefix}_end_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <joint name="arm_${prefix}_end_fixed" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="arm_${prefix}_link6" />
      <child link="arm_${prefix}_end_link" />
    </joint>

    <link name="gripper_${prefix}_base_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="1e-6" />
        <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
      </inertial>
    </link>
    <joint name="gripper_${prefix}_base_fixed" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="arm_${prefix}_end_link" />
      <child link="gripper_${prefix}_base_link" />
    </joint>

    <xacro:property name="active_mesh" value="link7" />
    <xacro:property name="passive_mesh" value="link8" />

    <link name="gripper_${prefix}_active_link">
      <inertial>
        <origin xyz="-0.000277778383727112 -0.0467673043650824 -0.00921029491873201" rpy="0 0 0" />
        <mass value="0.02648229234527" />
        <inertia ixx="9.99787479924589E-06" ixy="-1.57548495096104E-07" ixz="-2.71342775003487E-08"
          iyy="6.1795212293655E-06" iyz="-1.58939803580081E-06" izz="1.42102717246564E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/${gripper_mesh_subdir}/${active_mesh}.dae" />
        </geometry>
        <material_override><roughness>0.05</roughness><metallic>1.0</metallic></material_override>
      </visual>
      <xacro:if value="${gripper_mesh_subdir == 'piper_slave_meshes'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/piper_slave_meshes/convex/${active_mesh}_collision.STL" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${gripper_mesh_subdir == 'piper_master_meshes'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/piper_master_meshes/${active_mesh}.dae" />
          </geometry>
        </collision>
      </xacro:if>
    </link>
    <joint name="gripper_${prefix}_active_joint" type="prismatic">
      <origin xyz="${gripper7_xyz}" rpy="${gripper7_rpy}" />
      <parent link="gripper_${prefix}_base_link" />
      <child link="gripper_${prefix}_active_link" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.04" effort="10" velocity="1" />
    </joint>

    <link name="gripper_${prefix}_passive_link">
      <inertial>
        <origin xyz="0.000277816920932317 0.0467673824063769 -0.00921030054508036" rpy="0 0 0" />
        <mass value="0.0264822021416248" />
        <inertia ixx="9.99779119357223E-06" ixy="-1.57542283433504E-07" ixz="2.71367446701359E-08"
          iyy="6.17952441557932E-06" iyz="1.58939319453383E-06" izz="1.4210192754512E-05" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/${gripper_mesh_subdir}/${passive_mesh}.dae" />
        </geometry>
        <material_override><roughness>0.05</roughness><metallic>1.0</metallic></material_override>
      </visual>
      <xacro:if value="${gripper_mesh_subdir == 'piper_slave_meshes'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/piper_slave_meshes/convex/${passive_mesh}_collision.STL" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${gripper_mesh_subdir == 'piper_master_meshes'}">
        <collision>
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/piper_master_meshes/${passive_mesh}.dae" />
          </geometry>
        </collision>
      </xacro:if>
    </link>
    <joint name="gripper_${prefix}_passive_joint" type="prismatic">
      <origin xyz="${gripper8_xyz}" rpy="${gripper8_rpy}" />
      <parent link="gripper_${prefix}_base_link" />
      <child link="gripper_${prefix}_passive_link" />
      <axis xyz="0 0 1" />
      <limit lower="-0.04" upper="0" effort="10" velocity="1" />
      <mimic joint="gripper_${prefix}_active_joint" multiplier="-1" offset="0" />
    </joint>
  </xacro:macro>

  <!-- base_link is the URDF root. KDL requires the root to be massless,
       so the body shell mass and mesh live on the base_link_inertia
       sibling below (UR-style frame + _inertia pattern). The
       REP-105 base_footprint floor-projection frame is intentionally
       NOT in the URDF — it's published by an external node alongside
       the chassis odometry, since the transform from base_link to
       base_footprint depends on runtime state (suspension / wheel
       deflection / floor estimation).

       The <visual> below is a 1mm sphere with purpose="guide" — invisible
       in RViz/Isaac Sim viewports but it flips the Isaac Sim 6.0
       URDF→USD converter's ``is_ghost_link`` check to False so the
       converter authors body0=parent_link on every joint instead of
       body0=articulation_root (Newton-only convention that breaks PhysX).
       KDL is fine with <visual> on the root — it only forbids
       <inertial> there. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.001"/></geometry>
    </visual>
  </link>

  <!-- UR-style kinematic-frame + _inertia sibling: base_link is the empty
       kinematic anchor; base_link_inertia carries the body shell mesh and
       its mass. The diagnose tool's literal-name lookup will skip
       base_link from the inertial-injection rule because of this sibling. -->

  <link name="base_link_inertia">
    <!-- Lumped superstructure carried on top of the Tracer chassis:
         body shell + 2 camera stands + arm-mounting plate. The official
         aloha_tracer2 URDF authors three separate 3.736 kg blocks
         (body_Link, camera_stand_1_Link, camera_stand_2_Link); we
         consolidate them into a single base_link_inertia because our
         body.dae visual mesh already depicts all of it as one piece.

         Mass:    3.736 + 2 × 3.736 ≈ 11.2 kg.
         Inertia: about a 0.5 × 0.4 × 1.0 m bounding volume (Tracer-deck
         to camera-stand-top). Box formula I = m/12 · (sum of squared
         off-axis extents). Camera-stand height (z=0.87 m relative to
         body_Link in the upstream URDF) dominates Ixx/Iyy via the
         parallel-axis term — that's why both are large compared to the
         body shell alone. -->
    <inertial>
      <origin xyz="0.015 -0.028 0.4" rpy="0 0 0" />
      <mass value="11.2" />
      <inertia ixx="1.04" ixy="0" ixz="0" iyy="1.10" iyz="0" izz="0.38" />
    </inertial>
    <visual>
      <origin xyz="0 0 0.168" rpy="0 0 3.14" />
      <geometry>
        <mesh filename="${mesh_dir}/body.dae" />
      </geometry>
        <material_override><roughness>0.55</roughness><metallic>0.0</metallic></material_override>
    </visual>
  </link>
  <joint name="base_link_inertia_fixed" type="fixed">
    <origin xyz="0 0 -0.15" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="base_link_inertia" />
  </joint>

  <link name="chassis_link">
    <!-- Tracer2 base chassis (drives wheels + bears Tracer's own
         electronics). Values copied directly from the official
         aloha_tracer2 URDF (mobile_aloha_sim_ros2/aloha_new_description),
         which itself was SolidWorks-exported from AgileX's CAD —
         authoritative. The aloha-specific superstructure mass (body
         shell, camera stands, arm mounts) lives on base_link_inertia,
         not here. Visual mesh tracer_base_link_no_wheel.dae depicts
         only the Tracer chassis, matching the inertia source. -->
    <inertial>
      <origin xyz="-0.037979422359657 -0.00314478249004299 -0.0259198905321653" rpy="0 0 0" />
      <mass value="2.4239552885625" />
      <inertia
        ixx="0.0691541872284658"
        ixy="0.000423483205221006"
        ixz="-0.000201466160013829"
        iyy="0.0588857794520233"
        iyz="0.000250049528136794"
        izz="0.125132015686105" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry>
        <mesh filename="${mesh_dir}/tracer_base_link_no_wheel.dae" />
      </geometry>
        <material_override><roughness>0.2</roughness><metallic>0.0</metallic></material_override>
    </visual>
  </link>
  <joint name="chassis_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="chassis_link" />
  </joint>

  <link name="chassis_rwheel_link">
    <!-- Tracer2 drive wheel inertia (official aloha_tracer2 URDF):
         m=0.148 kg, cylinder r=0.06 m h=0.084 m. The official URDF
         numbers come from SolidWorks export. -->
    <inertial>
      <mass value="0.148" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.000131" ixy="0" ixz="0" iyy="0.000238" iyz="0" izz="0.000131" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_dir}/tracer_wheel.dae" />
      </geometry>
        <material_override><roughness>0.95</roughness><metallic>0.0</metallic></material_override>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.06" length="0.084" />
      </geometry>
    </collision>
  </link>
  <joint name="chassis_rwheel_joint" type="continuous">
    <parent link="chassis_link" />
    <child link="chassis_rwheel_link" />
    <origin xyz="0 -0.17 -0.082" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.05" friction="0.05" />
  </joint>

  <link name="chassis_lwheel_link">
    <!-- Mirror of chassis_rwheel_link — same wheel geometry, same mass. -->
    <inertial>
      <mass value="0.148" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.000131" ixy="0" ixz="0" iyy="0.000238" iyz="0" izz="0.000131" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="${mesh_dir}/tracer_wheel.dae" />
      </geometry>
        <material_override><roughness>0.95</roughness><metallic>0.0</metallic></material_override>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <cylinder radius="0.06" length="0.084" />
      </geometry>
    </collision>
  </link>
  <joint name="chassis_lwheel_joint" type="continuous">
    <parent link="chassis_link" />
    <child link="chassis_lwheel_link" />
    <origin xyz="0 0.17 -0.082" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <dynamics damping="0.05" friction="0.05" />
  </joint>

  <xacro:macro name="castor_assembly" params="prefix origin_xyz origin_rpy wheel_xyz">
    <link name="chassis_${prefix}_castor_link">
      <!-- Castor mount bracket (rotates about vertical axis above the
           wheel). Bracket-shaped ~0.085 m cube; mass split off from the
           Tracer2 official castor assembly (0.286 kg total) → ~0.2 kg
           mount + 0.086 kg wheel. -->
      <inertial>
        <mass value="0.2" />
        <origin xyz="0 0 0" />
        <inertia ixx="2.4e-4" ixy="0" ixz="0" iyy="2.4e-4" iyz="0" izz="2.4e-4" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_dir}/castor_joint.dae" />
        </geometry>
        <material_override><roughness>0.7</roughness><metallic>0.0</metallic></material_override>
      </visual>
    </link>
    <joint name="chassis_${prefix}_castor_joint" type="continuous">
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}" />
      <parent link="chassis_link" />
      <child link="chassis_${prefix}_castor_link" />
      <axis xyz="0 1 0" />
      <dynamics damping="0.1" friction="0.1" />
    </joint>
    <link name="chassis_${prefix}_link1">
      <!-- Castor wheel. Cylinder r=0.0375 m h=0.053 m, axis along Z
           (joint axis = 0 0 1). Mass = remainder of the 0.286 kg
           Tracer2 castor assembly after the bracket = 0.086 kg.
           Cylinder Z-axial inertia: Ixx = Iyy = m·(3r² + h²)/12 = 4.1e-5;
           Izz = m·r²/2 = 6.0e-5. -->
      <inertial>
        <mass value="0.086" />
        <origin xyz="0 0 0" />
        <inertia ixx="4.1e-5" ixy="0" ixz="0" iyy="4.1e-5" iyz="0" izz="6.0e-5" />
      </inertial>
      <visual>
        <geometry>
          <mesh filename="${mesh_dir}/castor.dae" />
        </geometry>
        <material_override><roughness>0.95</roughness><metallic>0.0</metallic></material_override>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <cylinder radius="0.0375" length="0.053" />
        </geometry>
      </collision>
    </link>
    <joint name="chassis_${prefix}_joint1" type="continuous">
      <parent link="chassis_${prefix}_castor_link" />
      <child link="chassis_${prefix}_link1" />
      <origin xyz="${wheel_xyz}" rpy="0 0 0" />
      <axis xyz="0 0 1" />
      <dynamics damping="0.05" friction="0.05" />
    </joint>
  </xacro:macro>

  <xacro:castor_assembly prefix="lwheel_front" origin_xyz="0.19 0.17 -0.038" origin_rpy="-1.57 0 0"
    wheel_xyz="-0.0218084 0.077 0" />
  <xacro:castor_assembly prefix="rwheel_front" origin_xyz="0.18955 -0.17 -0.0380886"
    origin_rpy="-1.57 0 0" wheel_xyz="-0.0218084 0.077 0" />
  <xacro:castor_assembly prefix="rwheel_rear" origin_xyz="-0.18955 -0.17 -0.0380886"
    origin_rpy="-1.57 0 0" wheel_xyz="-0.0218084 0.077 0" />
  <xacro:castor_assembly prefix="lwheel_rear" origin_xyz="-0.18955 0.17 -0.0380886"
    origin_rpy="-1.57 0 0" wheel_xyz="-0.0218084 0.077 0" />

  <!-- arm_base_link is a pure empty kinematic frame: just an attachment
       point for the four aloha_arm macros. The body shell mesh and mass
       it used to carry have moved to base_link_inertia (UR-style frame +
       _inertia sibling pattern). The diagnose tool skips empty links
       like this — they never become a RigidBodyAPI in the converted USD. -->
  <!-- arm_base_link is the 4-arm mount frame: a pure attachment point with
       no visual of its own. It still becomes a PhysX rigid body (it's an
       intermediate articulation node — child of base_link, parent of all
       four arms), so it needs a token <inertial> or PhysX warns about a
       massless body. Negligible mass; the real arm masses are on the arm
       links. Not the URDF root, so KDL is fine with inertia here. -->
  <link name="arm_base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1e-4"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="arm_base_joint" type="fixed">
    <origin xyz="0 0 -0.15" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="arm_base_link" />
  </joint>

  <xacro:aloha_arm prefix="fl" parent="arm_base_link"
    mount_xyz="0.23875 0.3 0.775" mount_rpy="0.0 0.0 0.0"
    gripper_mesh_subdir="piper_slave_meshes"
    gripper7_xyz="0 0 0.13503" gripper8_xyz="0 0 0.13503" />

  <xacro:aloha_arm prefix="fr" parent="arm_base_link"
    mount_xyz="0.23875 -0.3 0.775" mount_rpy="0.0 0.0 0.0"
    gripper_mesh_subdir="piper_slave_meshes"
    gripper7_xyz="0 0 0.13503" gripper8_xyz="0 0 0.13503" />

  <xacro:aloha_arm prefix="bl" parent="arm_base_link"
    mount_xyz="-0.379 0.3075 0.901" mount_rpy="0.0 0.0 0.0"
    gripper_mesh_subdir="piper_master_meshes"
    gripper7_xyz="0 -0.043177 0.0685" gripper8_xyz="0 -0.043177 0.0685" />

  <xacro:aloha_arm prefix="br" parent="arm_base_link"
    mount_xyz="-0.379 -0.3075 0.901" mount_rpy="0.0 0.0 0.0"
    gripper_mesh_subdir="piper_master_meshes"
    gripper7_xyz="0 -0.043177 0.0685" gripper8_xyz="0 -0.043177 0.0685" />

</robot>
