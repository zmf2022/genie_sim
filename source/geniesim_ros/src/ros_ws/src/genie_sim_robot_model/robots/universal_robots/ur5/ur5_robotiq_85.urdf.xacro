<?xml version="1.0"?>
<!--
  Universal Robots UR5 + Robotiq 2F-85 parallel gripper.

  Composes:
    1. The bare UR5 description (ur5.urdf.xacro), which provides the
       arx_x5-convention link/joint names (base_link as the REP-103 root,
       arm_base_link as the UR-internal-frame chain parent, arm_link1..6,
       arm_joint1..6, arm_end_link) and the canonical gripper_base_link
       mount point directly inside the UR macro.
    2. The vendored Robotiq 2F-85 macro, mounted on gripper_base_link
       (matching arx_x5 / agilex_piper).
-->
<robot name="ur5_robotiq_85" xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:include filename="$(find genie_sim_robot_model)/robots/universal_robots/ur5/ur5.urdf.xacro" />
  <xacro:include filename="$(find genie_sim_robot_model)/robots/universal_robots/ur5/gripper/robotiq_85/urdf/robotiq_2f_85_macro.urdf.xacro" />

  <xacro:arg name="tf_prefix" default="" />

  <xacro:robotiq_2f_85_gripper prefix="$(arg tf_prefix)" parent="$(arg tf_prefix)gripper_base_link" />

</robot>
