<?xml version="1.0"?>
<!--
  Robotiq 2F-85 parallel gripper macro (vendored).

  Source: PickNikRobotics/ros2_robotiq_gripper, robotiq_description package
    https://github.com/PickNikRobotics/ros2_robotiq_gripper
    robotiq_description/urdf/robotiq_2f_85_macro.urdf.xacro

  Adapted for the genie_sim_robot_model layout:
    - Mesh URIs rewritten from package://robotiq_description/meshes/{visual,collision}/2f_85/...
      to
package://genie_sim_robot_model/robots/universal_robots/ur5/gripper/robotiq_85/meshes/{visual,collision}/...
    - The ros2_control include is removed; this macro is description-only.
      Grippers are simulated through Isaac Sim joint commands rather than
      ros2_control, mirroring how arx_x5 / agilex_piper grippers are wired
      in this workspace.
    - Link / joint names blend two in-tree conventions:
        * swiftpicker for the inner/outer/tip link
          hierarchy along each finger.
        * arx_x5 / agilex_piper for the active/passive DOF labelling.
      The literal words 'left' / 'right' are dropped: the two fingers of a
      parallel gripper are distinguished by 'active' (the side carrying the
      master DOF, upstream's 'left') versus 'passive' (the mimic-driven side,
      upstream's 'right'). This keeps every name globally meaningful without
      an arbitrary handedness convention.

      Names emitted by this macro:
        Active-side links:  gripper_active_outer_link, gripper_active_inner_link,
                            gripper_active_outer_finger_link, gripper_active_finger_tip_link
        Passive-side links: gripper_passive_outer_link, gripper_passive_inner_link,
                            gripper_passive_outer_finger_link, gripper_passive_finger_tip_link
        Master DOF:         gripper_active_master_joint (drives gripper_active_outer_link;
                            this is the upstream finger_joint, kinematically the same
                            joint that controls gripper closing in the original Robotiq
                            URDF; suffix '_master' is a role-based rename adopted to
                            sidestep the importer bug described below.)
        Active-side mimics: gripper_active_slave_joint  (drives gripper_active_inner_link),
                            gripper_active_tip_joint
        Passive-side mimics:gripper_passive_master_joint (drives gripper_passive_outer_link),
                            gripper_passive_slave_joint  (drives gripper_passive_inner_link),
                            gripper_passive_tip_joint
        NOTE on master choice: the Isaac Sim URDF importer walks joints in
        alphabetical order of joint name (it iterates a std::map keyed by
        name in KinematicChain::computeChildNodes). When a mimic follower
        is processed before its master and they share the same parent link,
        the master prim does not yet exist on the USD stage, so the
        importer's FindPrimByNameAndType lookup returns null and the
        follower silently loses its referenceJoint relationship and its
        revolute limits (USD schema default ±inf), which then trips the
        PhysX mimic-joint validator. The original upstream master is the
        active-side outer-knuckle joint (kinematically preferred because
        driving the inner knuckle as master causes dynamics instability),
        but its upstream name 'finger_joint' / 'gripper_active_joint'
        sorts AFTER 'gripper_active_inner_joint', triggering the bug. We
        rename the four parent=${parent} active/passive inner/outer
        knuckle joints to use role-based suffixes 'master' / 'slave'
        instead of geometric 'outer' / 'inner', so 'master' (109='m') sorts
        before 'slave' (115='s') and the master is always authored first.
        Fixed connectors:   gripper_active_outer_finger_fixed, gripper_passive_outer_finger_fixed
    - Kinematics, inertials, joint limits, and mimic relationships are
      preserved verbatim (single master DOF; five revolute mimics with
      multipliers +1/-1 matching upstream; two fixed connector joints).
    - The upstream 'robotiq_85_base_link' / 'robotiq_85_base_joint' are
      dropped: the arm macro already provides 'gripper_base_link' as the
      mount point, so the gripper attaches its visual/collision/inertial
      content directly onto the parent (= gripper_base_link).

  Upstream license: BSD-3-Clause
-->
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="robotiq_gripper">
    <xacro:macro name="robotiq_2f_85_gripper" params="
        prefix
        parent">

        <xacro:property name="mesh_dir"
            value="package://genie_sim_robot_model/robots/universal_robots/ur5/gripper/robotiq_85/meshes" />

        <!-- Gripper body: visual / collision / inertial of the upstream
             'robotiq_85_base_link' are attached directly to the parent
             (gripper_base_link from the arm macro) so we do not introduce a
             redundant link + identity-fixed joint. -->
        <link name="${parent}_inertia">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/robotiq_base.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/robotiq_base.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.0 2.274e-05 0.03232288" rpy="0 0 0" />
                <mass value="6.6320197e-01" />
                <inertia ixx="5.1617816e-04" iyy="5.8802208e-04" izz="3.9462776e-04" ixy="2.936e-8"
                    ixz="0.0" iyz="-3.2296e-7" />
            </inertial>
        </link>
        <joint name="${prefix}gripper_base_inertia_fixed" type="fixed">
            <parent link="${parent}" />
            <child link="${parent}_inertia" />
            <origin xyz="0 0 0" rpy="0 0 0" />
        </joint>

        <link name="${prefix}gripper_active_outer_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/left_knuckle.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/left_knuckle.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.01213197 0.0002 -0.00058647" rpy="0 0 0" />
                <mass value="1.384773208e-02" />
                <inertia ixx="3.5232e-7" iyy="2.31944e-6" izz="2.23136e-6" ixy="0.0" ixz="1.1744e-7"
                    iyz="0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_passive_outer_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/right_knuckle.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/right_knuckle.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="-0.01213197 0.0002 -0.00058647" rpy="0 0 0" />
                <mass value="1.384773208e-02" />
                <inertia ixx="3.5232e-7" iyy="2.31944e-6" izz="2.23136e-6" ixy="0.0"
                    ixz="-1.1744e-7" iyz="0.0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_active_outer_finger_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/left_finger.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/left_finger.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.00346899 -0.00079447 0.01867121" rpy="0 0 0" />
                <mass value="4.260376752e-02" />
                <inertia ixx="1.385792000000000e-05" iyy="1.183208e-05" izz="5.19672e-06" ixy="0.0"
                    ixz="-2.17264e-06" iyz="0.0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_passive_outer_finger_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/right_finger.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/right_finger.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="-0.00346899 -5.53e-06 0.01867121" rpy="0 0 0" />
                <mass value="4.260376752000000e-02" />
                <inertia ixx="1.385792e-05" iyy="1.183208e-05" izz="5.19672e-06" ixy="0.0"
                    ixz="2.17264e-06" iyz="0.0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_active_inner_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/left_inner_knuckle.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/left_inner_knuckle.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.01897699 0.00015001 0.02247101" rpy="0 0 0" />
                <mass value="2.969376448e-02" />
                <inertia ixx="9.57136e-06" iyy="8.69056e-06" izz="8.19144e-06" ixy="0.0"
                    ixz="-3.93424e-06" iyz="0.0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_passive_inner_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/right_inner_knuckle.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/right_inner_knuckle.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="-0.01926824 5.001e-05 0.02222178" rpy="0 0 0" />
                <mass value="2.969376448e-02" />
                <inertia ixx="9.42456e-06" iyy="8.69056e-06" izz="8.33824e-06" ixy="0.0"
                    ixz="3.9636e-06" iyz="0.0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_active_finger_tip_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/left_finger_tip.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/left_finger_tip.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="-0.01456706 -0.0008 0.01649701" rpy="0 0 0" />
                <mass value="4.268588744e-02" />
                <inertia ixx="1.048152e-05" iyy="1.197888e-05" izz="4.22784e-06" ixy="0.0"
                    ixz="3.5232e-6" iyz="0.0" />
            </inertial>
        </link>

        <link name="${prefix}gripper_passive_finger_tip_link">
            <visual>
                <geometry>
                    <mesh filename="${mesh_dir}/visual/right_finger_tip.dae" />
                </geometry>
            </visual>
            <collision>
                <geometry>
                    <mesh filename="${mesh_dir}/collision/right_finger_tip.stl" />
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0.01456706 5e-05 0.01649701" rpy="0 0 0" />
                <mass value="4.268588744e-02" />
                <inertia ixx="1.048152e-05" iyy="1.197888e-05" izz="4.22784e-06" ixy="0.0"
                    ixz="-3.5232e-06" iyz="0.0" />
            </inertial>
        </link>

        <!-- Master DOF: drives the active-side outer knuckle.
             Upstream 'finger_joint'. Kinematically the canonical Robotiq
             drive (driving the inner knuckle instead causes dynamics
             instability). Renamed to '_master' so it sorts before its
             '_slave' siblings under parent ${parent} and is therefore
             authored on the USD stage before any mimic follower processes
             it (Isaac Sim importer alphabetical-order bug; see file
             header). -->
        <joint name="${prefix}gripper_active_master_joint" type="revolute">
            <parent link="${parent}" />
            <child link="${prefix}gripper_active_outer_link" />
            <axis xyz="0 -1 0" />
            <origin xyz="0.03060114 0.0 0.05490452" rpy="0 0 0" />
            <limit lower="0.0" upper="0.8" velocity="0.5" effort="50" />
        </joint>

        <!-- Active-side inner knuckle (mimic of master, same sign).
             Renamed from 'gripper_active_inner_joint' to
             'gripper_active_slave_joint' (role-based) so it sorts after
             the master under the same parent. -->
        <joint name="${prefix}gripper_active_slave_joint" type="revolute">
            <parent link="${parent}" />
            <child link="${prefix}gripper_active_inner_link" />
            <axis xyz="0 -1 0" />
            <origin xyz="0.0127 0.0 0.06142" rpy="0 0 0" />
            <limit lower="0.0" upper="0.8" velocity="0.5" effort="50" />
            <mimic joint="${prefix}gripper_active_master_joint" multiplier="1" />
        </joint>

        <!-- Passive-side outer knuckle (mimic of master, opposite sign).
             Renamed from 'gripper_passive_outer_joint' to
             'gripper_passive_master_joint' to mirror the active side. -->
        <joint name="${prefix}gripper_passive_master_joint" type="revolute">
            <parent link="${parent}" />
            <child link="${prefix}gripper_passive_outer_link" />
            <axis xyz="0 -1 0" />
            <origin xyz="-0.03060114 0.0 0.05490452" rpy="0 0 0" />
            <limit lower="-0.8" upper="0.0" velocity="0.5" effort="50" />
            <mimic joint="${prefix}gripper_active_master_joint" multiplier="-1" />
        </joint>

        <!-- Outer-finger fixed connectors (one per side). -->
        <joint name="${prefix}gripper_active_outer_finger_fixed" type="fixed">
            <parent link="${prefix}gripper_active_outer_link" />
            <child link="${prefix}gripper_active_outer_finger_link" />
            <origin xyz="0.03152616 0.0 -0.00376347" rpy="0 0 0" />
        </joint>

        <joint name="${prefix}gripper_passive_outer_finger_fixed" type="fixed">
            <parent link="${prefix}gripper_passive_outer_link" />
            <child link="${prefix}gripper_passive_outer_finger_link" />
            <origin xyz="-0.03152616 0.0 -0.00376347" rpy="0 0 0" />
        </joint>

        <!-- Passive-side inner knuckle (mimic of master, opposite sign).
             Renamed from 'gripper_passive_inner_joint' to
             'gripper_passive_slave_joint' (role-based).
             Empirical findings from clean-build experiments on this URDF:
             - The Isaac Sim URDF importer recognises a `<mimic>` element
               only when at least `multiplier` is explicit; bare
               `<mimic joint="X"/>` is silently dropped (the joint becomes
               free and helicopter-spins under the slightest torque).
             - The importer also requires `offset` to be IMPLICIT (omitted).
               Authoring `offset="0"` does not change semantics per the URDF
               spec but in practice routes the joint through a code path
               that drops `physics:lowerLimit/upperLimit`, leaving them
               +/-inf and tripping PhysX's mimic-joint validator.
             - Flipping `axis` to invert sign convention is also broken:
               with `axis="0 1 0"` and `multiplier="-1"` the importer
               produces +/-inf limits even with `offset` omitted. The
               kinematically-equivalent formulation that the importer
               actually handles correctly is the natural one: matching
               axis to the master and using the appropriate multiplier
               sign.
             So: keep axis matched to the master, use explicit
             `multiplier`, omit `offset`. -->
        <joint name="${prefix}gripper_passive_slave_joint" type="revolute">
            <parent link="${parent}" />
            <child link="${prefix}gripper_passive_inner_link" />
            <axis xyz="0 -1 0" />
            <origin xyz="-0.0127 0.0 0.06142" rpy="0 0 0" />
            <mimic joint="${prefix}gripper_active_master_joint" multiplier="-1" />
            <limit lower="-0.8" upper="0.0" velocity="0.5" effort="50" />
        </joint>

        <!-- Finger-tip mimics (one per side). Active-side tip rotates with
             opposite sign relative to master; passive-side tip with same
             sign. See passive-slave comment above for importer caveats. -->
        <joint name="${prefix}gripper_active_tip_joint" type="revolute">
            <parent link="${prefix}gripper_active_outer_finger_link" />
            <child link="${prefix}gripper_active_finger_tip_link" />
            <axis xyz="0 -1 0" />
            <origin xyz="0.00563134 0.0 0.04718515" rpy="0 0 0" />
            <mimic joint="${prefix}gripper_active_master_joint" multiplier="-1" />
            <limit lower="-0.8" upper="0.0" velocity="0.5" effort="50" />
        </joint>

        <joint name="${prefix}gripper_passive_tip_joint" type="revolute">
            <parent link="${prefix}gripper_passive_outer_finger_link" />
            <child link="${prefix}gripper_passive_finger_tip_link" />
            <axis xyz="0 -1 0" />
            <origin xyz="-0.00563134 0.0 0.04718515" rpy="0 0 0" />
            <mimic joint="${prefix}gripper_active_master_joint" multiplier="1" />
            <limit lower="0.0" upper="0.8" velocity="0.5" effort="50" />
        </joint>
    </xacro:macro>
</robot>
