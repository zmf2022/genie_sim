<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">
  <!--
    Base UR robot series xacro macro.

    NOTE this is NOT a URDF. It cannot directly be loaded by consumers
    expecting a flattened '.urdf' file. See the top-level '.xacro' for that
    (but note that .xacro must still be processed by the xacro command).

    This file models the base kinematic chain of a UR robot, which then gets
    parameterised by various configuration files to convert it into a UR3(e),
    UR5(e), UR10(e) or UR16e, etc.

    NOTE the default kinematic parameters (i.e., link lengths, frame locations,
    offsets, etc) do not correspond to any particular robot. They are defaults
    only. There WILL be non-zero offsets between the Forward Kinematics results
    in TF (i.e., robot_state_publisher) and the values reported by the Teach
    Pendant.

    For accurate (and robot-specific) transforms, the 'kinematics_parameters_file'
    parameter MUST point to a .yaml file containing the appropriate values for
    the targeted robot.

    If using the UniversalRobots/Universal_Robots_ROS_Driver, follow the steps
    described in the readme of that repository to extract the kinematic
    calibration from the controller and generate the required .yaml file.

    Main author of the migration to yaml configs Ludovic Delval.

    Contributors to previous versions (in no particular order)

     - Denis Stogl
     - Lovro Ivanov
     - Felix Messmer
     - Kelsey Hawkins
     - Wim Meeussen
     - Shaun Edwards
     - Nadia Hammoudeh Garcia
     - Dave Hershberger
     - G. vd. Hoorn
     - Philip Long
     - Dave Coleman
     - Miguel Prada
     - Mathias Luedtke
     - Marcel Schnirring
     - Felix von Drigalski
     - Felix Exner
     - Jimmy Da Silva
     - Ajit Krisshna N L
     - Muhammad Asif Rana
  -->

  <xacro:include filename="$(find genie_sim_robot_model)/robots/universal_robots/ur5/urdf/inc/ur_common.xacro" />

  <xacro:macro name="ur_robot" params="
    name
    tf_prefix
    joint_limits_parameters_file
    kinematics_parameters_file
    physical_parameters_file
    visual_parameters_file
    safety_limits:=false
    safety_pos_margin:=0.15
    safety_k_position:=20
    force_abs_paths:=false
    ">

    <!-- Load configuration data from the provided .yaml files -->
    <xacro:read_model_data
      joint_limits_parameters_file="${joint_limits_parameters_file}"
      kinematics_parameters_file="${kinematics_parameters_file}"
      physical_parameters_file="${physical_parameters_file}"
      visual_parameters_file="${visual_parameters_file}"
      force_abs_paths="${force_abs_paths}"/>

    <!-- links -  main serial chain -->

    <!-- base_link is the conventional ROS root, REP-103 aligned (X+ forward,
        Y+ left, Z+ up). It is intentionally an empty link: some kinematic
        solvers forbid having inertia attached to the root, so the visual /
        collision / inertia payload is carried by base_link_inertia, which
        hangs off base_link via a Z+pi rotation (because the upstream visual
        meshes were authored in the UR controller's internal "Base" frame,
        X+ backward).
        arm_base_link is the UR-internal-frame parent of the kinematic chain
        (arm_link1..6 / arm_joint1..6) and is reached from base_link via the
        same Z+pi rotation. Both arm_base_link and base_link_inertia are
        siblings under base_link.

        The 1mm guide-sphere <visual> on base_link flips the Isaac Sim 6.0
        URDF→USD converter's is_ghost_link check to False so it authors
        body0=parent_link on every joint. See
        genie_sim_robot_model/AGENTS.md → "Non-ghost root link pattern".
    -->
    <link name="${tf_prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="0.001"/></geometry>
      </visual>
    </link>
    <link name="${tf_prefix}arm_base_link"/>
    <link name="${tf_prefix}base_link_inertia">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
      <xacro:get_visual_params name="base" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="base" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="base" type="collision"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertial radius="${base_inertia_radius}" length="${base_inertia_length}" mass="${base_mass}">
        <origin xyz="0 0 0" rpy="0 0 0" />
      </xacro:cylinder_inertial>
    </link>
    <link name="${tf_prefix}arm_link1">
      <xacro:get_visual_params name="shoulder" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="shoulder" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="shoulder" type="collision"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${shoulder_mass}"/>
        <origin rpy="${shoulder_inertia_rotation}" xyz="${shoulder_cog}"/>
        <inertia
            ixx="${shoulder_inertia_ixx}"
            ixy="${shoulder_inertia_ixy}"
            ixz="${shoulder_inertia_ixz}"
            iyy="${shoulder_inertia_iyy}"
            iyz="${shoulder_inertia_iyz}"
            izz="${shoulder_inertia_izz}"
        />
      </inertial>    </link>
    <link name="${tf_prefix}arm_link2">
      <xacro:get_visual_params name="upper_arm" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="upper_arm" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="upper_arm" type="collision"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${upper_arm_mass}"/>
        <origin rpy="${upper_arm_inertia_rotation}" xyz="${upper_arm_cog}"/>
        <inertia
            ixx="${upper_arm_inertia_ixx}"
            ixy="${upper_arm_inertia_ixy}"
            ixz="${upper_arm_inertia_ixz}"
            iyy="${upper_arm_inertia_iyy}"
            iyz="${upper_arm_inertia_iyz}"
            izz="${upper_arm_inertia_izz}"
        />
      </inertial>
    </link>
    <link name="${tf_prefix}arm_link3">
      <xacro:get_visual_params name="forearm" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="forearm" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="forearm" type="collision"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${forearm_mass}"/>
        <origin rpy="${forearm_inertia_rotation}" xyz="${forearm_cog}"/>
        <inertia
            ixx="${forearm_inertia_ixx}"
            ixy="${forearm_inertia_ixy}"
            ixz="${forearm_inertia_ixz}"
            iyy="${forearm_inertia_iyy}"
            iyz="${forearm_inertia_iyz}"
            izz="${forearm_inertia_izz}"
        />
      </inertial>
    </link>
    <link name="${tf_prefix}arm_link4">
      <xacro:get_visual_params name="wrist_1" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="wrist_1" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="wrist_1" type="collision"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wrist_1_mass}"/>
        <origin rpy="${wrist_1_inertia_rotation}" xyz="${wrist_1_cog}"/>
        <inertia
            ixx="${wrist_1_inertia_ixx}"
            ixy="${wrist_1_inertia_ixy}"
            ixz="${wrist_1_inertia_ixz}"
            iyy="${wrist_1_inertia_iyy}"
            iyz="${wrist_1_inertia_iyz}"
            izz="${wrist_1_inertia_izz}"
        />
      </inertial>
    </link>
    <link name="${tf_prefix}arm_link5">
      <xacro:get_visual_params name="wrist_2" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="wrist_2" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="wrist_2" type="collision"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wrist_2_mass}"/>
        <origin rpy="${wrist_2_inertia_rotation}" xyz="${wrist_2_cog}"/>
        <inertia
            ixx="${wrist_2_inertia_ixx}"
            ixy="${wrist_2_inertia_ixy}"
            ixz="${wrist_2_inertia_ixz}"
            iyy="${wrist_2_inertia_iyy}"
            iyz="${wrist_2_inertia_iyz}"
            izz="${wrist_2_inertia_izz}"
        />
      </inertial>
    </link>
    <link name="${tf_prefix}arm_link6">
      <xacro:get_visual_params name="wrist_3" type="mesh_offset"/>
      <visual>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="wrist_3" type="visual"/>
        </geometry>
      </visual>
      <collision>
        <origin
         xyz="${visual_params['x']} ${visual_params['y']} ${visual_params['z']}"
         rpy="${visual_params['roll']} ${visual_params['pitch']} ${visual_params['yaw']}"/>
        <geometry>
          <xacro:get_mesh name="wrist_3" type="collision"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="${wrist_3_mass}"/>
        <origin rpy="${wrist_3_inertia_rotation}" xyz="${wrist_3_cog}"/>
        <inertia
            ixx="${wrist_3_inertia_ixx}"
            ixy="${wrist_3_inertia_ixy}"
            ixz="${wrist_3_inertia_ixz}"
            iyy="${wrist_3_inertia_iyy}"
            iyz="${wrist_3_inertia_iyz}"
            izz="${wrist_3_inertia_izz}"
        />
      </inertial>
    </link>

    <!-- joints - main serial chain -->
    <!-- base_link is REP-103 aligned (X+ forward); the UR controller's
         internal "Base" frame has X+ backward. Apply Rz(pi) to land in the
         UR-internal frame for both arm_base_link (kinematic chain root) and
         base_link_inertia (visual / collision / inertia payload, authored
         upstream in the UR-internal frame). -->
    <joint name="${tf_prefix}base_link-arm_base_link" type="fixed">
      <parent link="${tf_prefix}base_link" />
      <child link="${tf_prefix}arm_base_link" />
      <origin xyz="0 0 0" rpy="0 0 ${pi}" />
    </joint>
    <joint name="${tf_prefix}base_link-base_link_inertia" type="fixed">
      <parent link="${tf_prefix}base_link" />
      <child link="${tf_prefix}base_link_inertia" />
      <origin xyz="0 0 0" rpy="0 0 ${pi}" />
    </joint>
    <joint name="${tf_prefix}arm_joint1" type="revolute">
      <parent link="${tf_prefix}arm_base_link" />
      <child link="${tf_prefix}arm_link1" />
      <origin xyz="${shoulder_x} ${shoulder_y} ${shoulder_z}" rpy="${shoulder_roll} ${shoulder_pitch} ${shoulder_yaw}" />
      <axis xyz="0 0 1" />
      <limit lower="${shoulder_pan_lower_limit}" upper="${shoulder_pan_upper_limit}"
        effort="${shoulder_pan_effort_limit}" velocity="${shoulder_pan_velocity_limit}"/>
      <xacro:if value="${safety_limits}">
         <safety_controller soft_lower_limit="${shoulder_pan_lower_limit + safety_pos_margin}" soft_upper_limit="${shoulder_pan_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0"/>
      </xacro:if>
      <dynamics damping="0" friction="0"/>
    </joint>
    <joint name="${tf_prefix}arm_joint2" type="revolute">
      <parent link="${tf_prefix}arm_link1" />
      <child link="${tf_prefix}arm_link2" />
      <origin xyz="${upper_arm_x} ${upper_arm_y} ${upper_arm_z}" rpy="${upper_arm_roll} ${upper_arm_pitch} ${upper_arm_yaw}" />
      <axis xyz="0 0 1" />
      <limit lower="${shoulder_lift_lower_limit}" upper="${shoulder_lift_upper_limit}"
        effort="${shoulder_lift_effort_limit}" velocity="${shoulder_lift_velocity_limit}"/>
      <xacro:if value="${safety_limits}">
         <safety_controller soft_lower_limit="${shoulder_lift_lower_limit + safety_pos_margin}" soft_upper_limit="${shoulder_lift_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0"/>
      </xacro:if>
      <dynamics damping="0" friction="0"/>
    </joint>
    <joint name="${tf_prefix}arm_joint3" type="revolute">
      <parent link="${tf_prefix}arm_link2" />
      <child link="${tf_prefix}arm_link3" />
      <origin xyz="${forearm_x} ${forearm_y} ${forearm_z}" rpy="${forearm_roll} ${forearm_pitch} ${forearm_yaw}" />
      <axis xyz="0 0 1" />
      <limit lower="${elbow_joint_lower_limit}" upper="${elbow_joint_upper_limit}"
        effort="${elbow_joint_effort_limit}" velocity="${elbow_joint_velocity_limit}"/>
      <xacro:if value="${safety_limits}">
         <safety_controller soft_lower_limit="${elbow_joint_lower_limit + safety_pos_margin}" soft_upper_limit="${elbow_joint_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0"/>
      </xacro:if>
      <dynamics damping="0" friction="0"/>
    </joint>
    <joint name="${tf_prefix}arm_joint4" type="revolute">
      <parent link="${tf_prefix}arm_link3" />
      <child link="${tf_prefix}arm_link4" />
      <origin xyz="${wrist_1_x} ${wrist_1_y} ${wrist_1_z}" rpy="${wrist_1_roll} ${wrist_1_pitch} ${wrist_1_yaw}" />
      <axis xyz="0 0 1" />
      <limit lower="${wrist_1_lower_limit}" upper="${wrist_1_upper_limit}"
        effort="${wrist_1_effort_limit}" velocity="${wrist_1_velocity_limit}"/>
      <xacro:if value="${safety_limits}">
         <safety_controller soft_lower_limit="${wrist_1_lower_limit + safety_pos_margin}" soft_upper_limit="${wrist_1_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0"/>
      </xacro:if>
      <dynamics damping="0" friction="0"/>
    </joint>
    <joint name="${tf_prefix}arm_joint5" type="revolute">
      <parent link="${tf_prefix}arm_link4" />
      <child link="${tf_prefix}arm_link5" />
      <origin xyz="${wrist_2_x} ${wrist_2_y} ${wrist_2_z}" rpy="${wrist_2_roll} ${wrist_2_pitch} ${wrist_2_yaw}" />
      <axis xyz="0 0 1" />
      <limit lower="${wrist_2_lower_limit}" upper="${wrist_2_upper_limit}"
             effort="${wrist_2_effort_limit}" velocity="${wrist_2_velocity_limit}"/>
      <xacro:if value="${safety_limits}">
         <safety_controller soft_lower_limit="${wrist_2_lower_limit + safety_pos_margin}" soft_upper_limit="${wrist_2_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0"/>
      </xacro:if>
      <dynamics damping="0" friction="0"/>
    </joint>
    <joint name="${tf_prefix}arm_joint6" type="${wrist_3_joint_type}">
      <parent link="${tf_prefix}arm_link5" />
      <child link="${tf_prefix}arm_link6" />
      <origin xyz="${wrist_3_x} ${wrist_3_y} ${wrist_3_z}" rpy="${wrist_3_roll} ${wrist_3_pitch} ${wrist_3_yaw}" />
      <axis xyz="0 0 1" />
      <xacro:if value="${wrist_3_joint_type != 'continuous'}">
        <limit lower="${wrist_3_lower_limit}" upper="${wrist_3_upper_limit}"
          effort="${wrist_3_effort_limit}" velocity="${wrist_3_velocity_limit}"/>
        <xacro:if value="${safety_limits}">
          <safety_controller soft_lower_limit="${wrist_3_lower_limit + safety_pos_margin}" soft_upper_limit="${wrist_3_upper_limit - safety_pos_margin}" k_position="${safety_k_position}" k_velocity="0.0"/>
        </xacro:if>
      </xacro:if>
      <xacro:unless value="${wrist_3_joint_type != 'continuous'}">
        <limit effort="${wrist_3_effort_limit}" velocity="${wrist_3_velocity_limit}"/>
        <xacro:if value="${safety_limits}">
          <safety_controller k_position="${safety_k_position}" k_velocity="0.0"/>
        </xacro:if>
      </xacro:unless>
      <dynamics damping="0" friction="0"/>
    </joint>

    <!-- Tool-frame attachment point. The upstream UR macro inserted a
         'flange' link rotated by rpy=(0, -pi/2, -pi/2) followed by a second
         rotation rpy=(pi/2, 0, pi/2) to land on the ROS-Industrial 'tool0'
         frame. The two rotations compose to identity, so we collapse them
         into a single identity-fixed joint and drop the 'flange' link
         entirely (one less link / joint to maintain). arm_end_link IS the
         flange / tool0 frame. -->
    <link name="${tf_prefix}arm_end_link"/>
    <joint name="${tf_prefix}arm_link6-arm_end_link" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${tf_prefix}arm_link6"/>
      <child link="${tf_prefix}arm_end_link"/>
    </joint>

    <!-- Canonical end-effector mount point matching arx_x5 / agilex_piper:
         identity-fixed under arm_end_link so external gripper macros can
         attach with a stable parent regardless of tool-frame rotation. -->
    <link name="${tf_prefix}gripper_base_link"/>
    <joint name="${tf_prefix}arm_end_link-gripper_base_link" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="${tf_prefix}arm_end_link"/>
      <child link="${tf_prefix}gripper_base_link"/>
    </joint>

  </xacro:macro>
</robot>
