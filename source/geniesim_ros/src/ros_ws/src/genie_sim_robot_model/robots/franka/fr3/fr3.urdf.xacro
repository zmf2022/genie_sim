<?xml version="1.0"?>
<!--
  Franka Research 3 (FR3) robot description.

  Adapted from the upstream franka_description URDF (the source the
  src/external/franka_ros2/franka_description package would generate)
  with link/joint names rewritten to match the in-tree arx_x5 / agilex_piper
  naming convention so all single-arm robots in genie_sim_robot_model
  share a common kinematic surface.

  Conventions (aligned with arx_x5):
    - The chain root is base_link, which carries the upstream link0
      visual+collision+inertia. The empty upstream base_link and the
      identity base_joint shim are dropped.
    - Revolute joints joint1..7 -> arm_joint1..7; their child links
      link1..7 -> arm_link1..7.
    - The fixed flange link8 (107 mm offset along Z from the last
      revolute joint, the 'NE' frame in Franka terminology) is renamed
      to arm_end_link, and its parent joint joint8 -> arm_end_fixed.
    - The hand (FR3 'EE' frame, with the upstream Rz(-pi/4) baked in
      via gripper_base_fixed) is gripper_base_link; the TCP frame is
      gripper_tcp_link (preserved at +0.1034 m along Z from
      gripper_base_link).
    - Parallel finger pair: master = gripper_active_link / gripper_active_joint
      (formerly fr3_leftfinger / fr3_finger_joint1); mimic = gripper_passive_link
      / gripper_passive_joint (formerly fr3_rightfinger / fr3_finger_joint2,
      preserving the upstream rpy="0 0 pi" handedness flip and
      multiplier="+1" mimic).
    - FR3 hardware accelerometer auxiliary frames are kept and renamed
      consistently: link0_accelerometer_* -> base_link_accelerometer_*,
      link{1..5}_accelerometer_* -> arm_link{1..5}_accelerometer_*.
    - Mesh files renamed accordingly:
        link0.{dae,stl} -> base_link.{dae,stl}
        link{1..7}.{dae,stl} -> arm_link{1..7}.{dae,stl}
        hand/hand.{dae,stl} -> hand/gripper_base_link.{dae,stl}
        hand/finger.dae -> hand/gripper_finger_link.dae (shared by both fingers)
-->
<robot name="franka_fr3"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_dir" value="package://genie_sim_robot_model/robots/franka/fr3/meshes" />

  <!-- base_link is intentionally an empty link so it can serve as the KDL
       root: kdl_parser rejects a root link that carries inertia. The
       visual / collision / inertial payload (upstream link0) is moved to
       base_link_inertia, a child of base_link via an identity-transform
       fixed joint. The kinematic chain (arm_joint1 ...) and the two
       accelerometer frames still hang off base_link, so no downstream
       link/joint names change.

       The 1mm guide-sphere <visual> below flips the Isaac Sim 6.0
       URDF→USD converter's is_ghost_link check to False so it authors
       body0=parent_link on every joint. See
       genie_sim_robot_model/AGENTS.md → "Non-ghost root link pattern". -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.001"/></geometry>
    </visual>
  </link>
  <link name="base_link_inertia">
    <visual name="base_link_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/base_link.dae"/>
      </geometry>
    </visual>
    <collision name="base_link_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/base_link.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0172 0.0004 0.0745"/>
      <mass value="2.3966"/>
      <inertia ixx="0.009" ixy="0.0" ixz="0.002" iyy="0.0115" iyz="0.0" izz="0.0085"/>
    </inertial>
  </link>
  <joint name="base_link-base_link_inertia" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="base_link_inertia"/>
  </joint>
  <link name="base_link_accelerometer_top"/>
  <joint name="base_link_accelerometer_top_joint" type="fixed">
    <origin rpy="3.1416 0.0 0.0" xyz="-0.017402 -0.007872 0.04715"/>
    <parent link="base_link"/>
    <child link="base_link_accelerometer_top"/>
  </joint>
  <link name="base_link_accelerometer_bottom"/>
  <joint name="base_link_accelerometer_bottom_joint" type="fixed">
    <origin rpy="0.0 0.0 -1.5708" xyz="-0.019739 0.0015506 0.05075"/>
    <parent link="base_link"/>
    <child link="base_link_accelerometer_bottom"/>
  </joint>

  <link name="arm_link1">
    <visual name="arm_link1_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link1.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link1_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link1.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0000004128 -0.0181251324 -0.0386035970"/>
      <mass value="2.9274653454"/>
      <inertia ixx="0.023927316485107913" ixy="1.3317903455714081e-05" ixz="-0.00011404774918616684" iyy="0.0224821613275756" iyz="-0.0019950320628240115" izz="0.006350098258530016"/>
    </inertial>
  </link>
  <link name="arm_link1_accelerometer_top"/>
  <joint name="arm_link1_accelerometer_top_joint" type="fixed">
    <origin rpy="-1.5708 0.0 3.1416" xyz="0.017402 -0.093352 -0.00787"/>
    <parent link="arm_link1"/>
    <child link="arm_link1_accelerometer_top"/>
  </joint>
  <link name="arm_link1_accelerometer_bottom"/>
  <joint name="arm_link1_accelerometer_bottom_joint" type="fixed">
    <origin rpy="-1.5708 1.5708 0.0" xyz="0.01974 -0.08975 0.00155"/>
    <parent link="arm_link1"/>
    <child link="arm_link1_accelerometer_bottom"/>
  </joint>
  <joint name="arm_joint1" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.333"/>
    <parent link="base_link"/>
    <child link="arm_link1"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-2.9007" upper="2.9007" velocity="2.62"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.9007" soft_upper_limit="2.9007"/>
    <position_based_velocity_limits deceleration_limit="6.0" velocity_offset="0.652"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="120.0" motor_inertia="4.206399e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <link name="arm_link2">
    <visual name="arm_link2_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link2.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link2_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link2.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0031828864 -0.0743221644 0.0088146084"/>
      <mass value="2.9355370338"/>
      <inertia ixx="0.041938946257609425" ixy="0.00020257331521090626" ixz="0.004077784227179924" iyy="0.02514514885014724" iyz="-0.0042252158006570156" izz="0.06170214472888839"/>
    </inertial>
  </link>
  <link name="arm_link2_accelerometer_top"/>
  <joint name="arm_link2_accelerometer_top_joint" type="fixed">
    <origin rpy="1.5708 0.0 3.1416" xyz="0.017403 -0.11715 0.00787"/>
    <parent link="arm_link2"/>
    <child link="arm_link2_accelerometer_top"/>
  </joint>
  <link name="arm_link2_accelerometer_bottom"/>
  <joint name="arm_link2_accelerometer_bottom_joint" type="fixed">
    <origin rpy="1.5708 -1.5708 0.0" xyz="0.019737 -0.11875 -0.00155"/>
    <parent link="arm_link2"/>
    <child link="arm_link2_accelerometer_bottom"/>
  </joint>
  <joint name="arm_joint2" type="revolute">
    <origin rpy="-1.570796326794897 0 0" xyz="0 0 0"/>
    <parent link="arm_link1"/>
    <child link="arm_link2"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-1.8361" upper="1.8361" velocity="2.62"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-1.8361" soft_upper_limit="1.8361"/>
    <position_based_velocity_limits deceleration_limit="2.585" velocity_offset="0.25"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="120.0" motor_inertia="4.206399e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <link name="arm_link3">
    <visual name="arm_link3_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link3.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link3_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link3.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0407015686 -0.0048200565 -0.0289730823"/>
      <mass value="2.2449013699"/>
      <inertia ixx="0.02410142547240885" ixy="0.002404694559042109" ixz="-0.002856269270114313" iyy="0.01974053266708178" iyz="-0.002104212683891874" izz="0.019044494482244823"/>
    </inertial>
  </link>
  <link name="arm_link3_accelerometer_top"/>
  <joint name="arm_link3_accelerometer_top_joint" type="fixed">
    <origin rpy="-1.5708 0.0 0.0" xyz="0.065099 0.077352 -0.00787"/>
    <parent link="arm_link3"/>
    <child link="arm_link3_accelerometer_top"/>
  </joint>
  <link name="arm_link3_accelerometer_bottom"/>
  <joint name="arm_link3_accelerometer_bottom_joint" type="fixed">
    <origin rpy="1.5708 1.5708 0.0" xyz="0.062769 0.073756 0.00155"/>
    <parent link="arm_link3"/>
    <child link="arm_link3_accelerometer_bottom"/>
  </joint>
  <joint name="arm_joint3" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0 -0.316 0"/>
    <parent link="arm_link2"/>
    <child link="arm_link3"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-2.9007" upper="2.9007" velocity="2.62"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.9007" soft_upper_limit="2.9007"/>
    <position_based_velocity_limits deceleration_limit="3.5" velocity_offset="0.2005"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="120.0" motor_inertia="3.211626e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <link name="arm_link4">
    <visual name="arm_link4_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link4.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link4_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link4.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0459100965 0.0630492960 -0.0085187868"/>
      <mass value="2.6155955791"/>
      <inertia ixx="0.03452998321913202" ixy="0.01322552265982813" ixz="0.01015142998484113" iyy="0.028881621933049058" iyz="-0.0009762833870704552" izz="0.04125471171146641"/>
    </inertial>
  </link>
  <link name="arm_link4_accelerometer_top"/>
  <joint name="arm_link4_accelerometer_top_joint" type="fixed">
    <origin rpy="-1.5708 0.0 -3.1416" xyz="-0.0651 0.046252 -0.00787"/>
    <parent link="arm_link4"/>
    <child link="arm_link4_accelerometer_top"/>
  </joint>
  <link name="arm_link4_accelerometer_bottom"/>
  <joint name="arm_link4_accelerometer_bottom_joint" type="fixed">
    <origin rpy="-1.5708 1.5708 0.0" xyz="-0.062775 0.049753 0.00155"/>
    <parent link="arm_link4"/>
    <child link="arm_link4_accelerometer_bottom"/>
  </joint>
  <joint name="arm_joint4" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0.0825 0 0"/>
    <parent link="arm_link3"/>
    <child link="arm_link4"/>
    <axis xyz="0 0 1"/>
    <limit effort="87.0" lower="-3.077" upper="-0.1169" velocity="2.62"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-3.077" soft_upper_limit="-0.1169"/>
    <position_based_velocity_limits deceleration_limit="4.0" velocity_offset="0.3542"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="120.0" motor_inertia="3.211626e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <link name="arm_link5">
    <visual name="arm_link5_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link5.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link5_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link5.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0016039605 0.0292536262 -0.0972965990"/>
      <mass value="2.3271207594"/>
      <inertia ixx="0.051610278463662895" ixy="-0.005715173387783472" ixz="-0.0035673167625872135" iyy="0.04787729713371481" iyz="0.010673985108535986" izz="0.016423625579357254"/>
    </inertial>
  </link>
  <link name="arm_link5_accelerometer_top"/>
  <joint name="arm_link5_accelerometer_top_joint" type="fixed">
    <origin rpy="-1.5708 0.0 0.0" xyz="-0.017363 0.085872 -0.00795"/>
    <parent link="arm_link5"/>
    <child link="arm_link5_accelerometer_top"/>
  </joint>
  <link name="arm_link5_accelerometer_bottom"/>
  <joint name="arm_link5_accelerometer_bottom_joint" type="fixed">
    <origin rpy="1.5708 1.5708 0.0" xyz="-0.019742 0.082275 0.00146"/>
    <parent link="arm_link5"/>
    <child link="arm_link5_accelerometer_bottom"/>
  </joint>
  <joint name="arm_joint5" type="revolute">
    <origin rpy="-1.570796326794897 0 0" xyz="-0.0825 0.384 0"/>
    <parent link="arm_link4"/>
    <child link="arm_link5"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-2.8763" upper="2.8763" velocity="5.26"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-2.8763" soft_upper_limit="2.8763"/>
    <position_based_velocity_limits deceleration_limit="17.0" velocity_offset="0.5738"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="80.0" motor_inertia="3.211626e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <link name="arm_link6">
    <visual name="arm_link6_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link6.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link6_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link6.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0597131221 -0.0410294666 -0.0101692726"/>
      <mass value="1.8170376524"/>
      <inertia ixx="0.005412333594383447" ixy="0.006193456360285834" ixz="0.0014219289306117652" iyy="0.014058329545509979" iyz="-0.0013140753741120031" izz="0.016080817924212554"/>
    </inertial>
  </link>
  <joint name="arm_joint6" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0 0 0"/>
    <parent link="arm_link5"/>
    <child link="arm_link6"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="0.4398" upper="4.6216" velocity="4.18"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="0.4398" soft_upper_limit="4.6216"/>
    <position_based_velocity_limits deceleration_limit="5.5" velocity_offset="0.4885"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="80.0" motor_inertia="3.211626e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <link name="arm_link7">
    <visual name="arm_link7_visual">
      <geometry>
        <mesh filename="${mesh_dir}/visual/arm_link7.dae"/>
      </geometry>
    </visual>
    <collision name="arm_link7_collision">
      <geometry>
        <mesh filename="${mesh_dir}/collision/arm_link7.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0.0045225817 0.0086261921 -0.0161633251"/>
      <mass value="0.6271432862"/>
      <inertia ixx="0.00021092389150104718" ixy="-2.433299114461931e-05" ixz="4.564480393778983e-05" iyy="0.00017718568002411474" iyz="8.744070223226438e-05" izz="5.993190599659971e-05"/>
    </inertial>
  </link>
  <joint name="arm_joint7" type="revolute">
    <origin rpy="1.570796326794897 0 0" xyz="0.088 0 0"/>
    <parent link="arm_link6"/>
    <child link="arm_link7"/>
    <axis xyz="0 0 1"/>
    <limit effort="12.0" lower="-3.0508" upper="3.0508" velocity="5.26"/>
    <safety_controller k_position="100.0" k_velocity="40.0" soft_lower_limit="-3.0508" soft_upper_limit="3.0508"/>
    <position_based_velocity_limits deceleration_limit="17.0" velocity_offset="0.4592"/>
    <dynamics D="1" K="7000" damping="0.003" friction="0.2" gear_ratio="80.0" motor_inertia="3.211626e-05" mu_coulomb="0" mu_viscous="16"/>
  </joint>

  <!-- Fixed flange (FR3 'NE' frame: 107 mm along Z from arm_link7). -->
  <link name="arm_end_link"/>
  <joint name="arm_end_fixed" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.107"/>
    <parent link="arm_link7"/>
    <child link="arm_end_link"/>
  </joint>

  <!-- Hand mount (FR3 'EE' frame: Rz(-pi/4) from arm_end_link). -->
  <link name="gripper_base_link">
    <visual name="gripper_base_link_visual">
      <geometry>
        <mesh filename="${mesh_dir}/hand/visual/gripper_base_link.dae"/>
      </geometry>
    </visual>
    <collision name="gripper_base_link_collision">
      <geometry>
        <mesh filename="${mesh_dir}/hand/collision/gripper_base_link.stl"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0000376 0.0119128 0.0207260"/>
      <mass value="0.6544"/>
      <inertia ixx="0.00186" ixy="0.0" ixz="0.0" iyy="0.0003" iyz="-2e-05" izz="0.00174"/>
    </inertial>
  </link>
  <joint name="gripper_base_fixed" type="fixed">
    <parent link="arm_end_link"/>
    <child link="gripper_base_link"/>
    <origin rpy="0 0 -0.7853981633974483" xyz="0 0 0"/>
  </joint>

  <!-- Tool centre point (FR3 'TCP' frame: 103.4 mm along Z from gripper_base_link). -->
  <link name="gripper_tcp_link"/>
  <joint name="gripper_tcp_fixed" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0.1034"/>
    <parent link="gripper_base_link"/>
    <child link="gripper_tcp_link"/>
  </joint>

  <link name="gripper_active_link">
    <visual name="gripper_active_link_visual">
      <geometry>
        <mesh filename="${mesh_dir}/hand/visual/gripper_finger_link.dae"/>
      </geometry>
    </visual>
    <!-- screw mount -->
    <collision>
      <origin rpy="0 0 0" xyz="0 18.5e-3 11e-3"/>
      <geometry>
        <box size="22e-3 15e-3 20e-3"/>
      </geometry>
    </collision>
    <!-- cartriage sledge -->
    <collision>
      <origin rpy="0 0 0" xyz="0 6.8e-3 2.2e-3"/>
      <geometry>
        <box size="22e-3 8.8e-3 3.8e-3"/>
      </geometry>
    </collision>
    <!-- diagonal finger -->
    <collision>
      <origin rpy="0.5235987755982988 0 0" xyz="0 15.9e-3 28.35e-3"/>
      <geometry>
        <box size="17.5e-3 7e-3 23.5e-3"/>
      </geometry>
    </collision>
    <!-- rubber tip with which to grasp -->
    <collision>
      <origin rpy="0 0 0" xyz="0 7.58e-3 45.25e-3"/>
      <geometry>
        <box size="17.5e-3 15.2e-3 18.5e-3"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0.0152850 0.0219675"/>
      <mass value="0.0291"/>
      <inertia ixx="8.49e-06" ixy="0.0" ixz="0.0" iyy="8.53e-06" iyz="-1.06e-06" izz="1.77e-06"/>
    </inertial>
  </link>
  <link name="gripper_passive_link">
    <visual name="gripper_passive_link_visual">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="${mesh_dir}/hand/visual/gripper_finger_link.dae"/>
      </geometry>
    </visual>
    <!-- screw mount -->
    <collision>
      <origin rpy="0 0 0" xyz="0 18.5e-3 11e-3"/>
      <geometry>
        <box size="22e-3 15e-3 20e-3"/>
      </geometry>
    </collision>
    <!-- cartriage sledge -->
    <collision>
      <origin rpy="0 0 0" xyz="0 6.8e-3 2.2e-3"/>
      <geometry>
        <box size="22e-3 8.8e-3 3.8e-3"/>
      </geometry>
    </collision>
    <!-- diagonal finger (sign-flipped relative to active side) -->
    <collision>
      <origin rpy="-0.5235987755982988 0 3.141592653589793" xyz="0 15.9e-3 28.35e-3"/>
      <geometry>
        <box size="17.5e-3 7e-3 23.5e-3"/>
      </geometry>
    </collision>
    <!-- rubber tip with which to grasp -->
    <collision>
      <origin rpy="0 0 0" xyz="0 7.58e-3 45.25e-3"/>
      <geometry>
        <box size="17.5e-3 15.2e-3 18.5e-3"/>
      </geometry>
    </collision>
    <inertial>
