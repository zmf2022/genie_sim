<?xml version="1.0"?>
<!--
  ARX X5A robot description.

  Adapted from src/external/ARX_Model/X5/X5A/urdf/X5A.urdf with mesh
  paths rewritten to package://genie_sim_robot_model/robots/arx/x5/meshes/
  so the model works in an ament workspace without building the original
  catkin-based X5A package.

  Original: SolidWorks URDF Exporter
  6-DOF revolute arm + parallel prismatic gripper.

  Conventions (aligned with arx_acone, single-arm flavor):
    - Links/joints renamed from link1..6 / joint1..6 to arm_link1..6 /
      arm_joint1..6 to match the arx_acone family.
    - Gripper link/joint pairs use active/passive naming: the master DOF
      is gripper_active_joint (formerly joint8) and the mimic DOF is
      gripper_passive_joint (formerly joint7), so the kinematic master is
      no longer the SolidWorks export's first-listed prismatic.
    - Mesh files renamed accordingly (link*.STL -> arm_link*.STL,
      link7.STL -> gripper_passive_link.STL, link8.STL ->
      gripper_active_link.STL).
    - After arm_link6: arm_end_link and gripper_base_link (identity
      fixed joints) so camera paths like /G2/gripper_base_link/... match
      other robot descriptions.
-->
<robot name="X5A"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_dir" value="package://genie_sim_robot_model/robots/arx/x5/meshes" />

  <!-- base_link is intentionally an empty link so it can serve as the KDL
       root: kdl_parser rejects a root link that carries inertia. The
       visual / collision / inertial payload is moved to base_link_inertia,
       a child of base_link via an identity-transform fixed joint. The
       kinematic chain (arm_joint1 ...) still hangs off base_link, so no
       downstream link/joint names change.

       The 1mm guide-sphere <visual> below flips the Isaac Sim 6.0
       URDF→USD converter's is_ghost_link check to False so it authors
       body0=parent_link on every joint. See
       genie_sim_robot_model/AGENTS.md → "Non-ghost root link pattern". -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.001"/></geometry>
    </visual>
  </link>
  <link name="base_link_inertia">
    <inertial>
      <origin xyz="-3.0001E-05 3.0589E-05 0.027324" rpy="0 0 0" />
      <mass value="0.43995" />
      <inertia ixx="0.00017" ixy="0.00000" ixz="0.00000" iyy="0.00017" iyz="0.00000" izz="0.00016" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/base_link.STL" /></geometry>
      <material name=""><color rgba="0.75294 0.75294 0.75294 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/base_link.STL" /></geometry>
    </collision>
  </link>
  <joint name="base_link-base_link_inertia" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="base_link_inertia" />
  </joint>

  <link name="arm_link1">
    <inertial>
      <origin xyz="0.0054231 -0.0080289 0.017086" rpy="0 0 0" />
      <mass value="0.066982" />
      <inertia ixx="0.00008" ixy="0.00000" ixz="0.00001" iyy="0.00003" iyz="0.00000" izz="0.00008" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link1.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.93333 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link1.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint1" type="revolute">
    <origin xyz="0 0 0.0605" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="arm_link1" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14159" upper="3.14159" effort="30" velocity="5.0" />
  </joint>

  <link name="arm_link2">
    <inertial>
      <origin xyz="-0.13237 0.0020852 0.00010549" rpy="0 0 0" />
      <mass value="1.0795" />
      <inertia ixx="0.00051" ixy="0.00001" ixz="-0.00004" iyy="0.01599" iyz="0.00000" izz="0.01605" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link2.STL" /></geometry>
      <material name=""><color rgba="0.75294 0.75294 0.75294 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link2.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint2" type="revolute">
    <origin xyz="0.02 0 0.04" rpy="0 0 0" />
    <parent link="arm_link1" />
    <child link="arm_link2" />
    <axis xyz="0 1 0" />
    <limit lower="-0.05" upper="3.5" effort="40" velocity="5.0" />
  </joint>

  <link name="arm_link3">
    <inertial>
      <origin xyz="0.18531 0.00068376 -0.051638" rpy="0 0 0" />
      <mass value="0.54534" />
      <inertia ixx="0.00036" ixy="-0.00003" ixz="-0.00039" iyy="0.00423" iyz="0.00001" izz="0.00420" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link3.STL" /></geometry>
      <material name=""><color rgba="1 0.98431 0.96471 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link3.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint3" type="revolute">
    <origin xyz="-0.264 0 0" rpy="3.1416 0 0" />
    <parent link="arm_link2" />
    <child link="arm_link3" />
    <axis xyz="0 1 0" />
    <limit lower="0.0" upper="3.2" effort="30" velocity="5.5" />
  </joint>

  <link name="arm_link4">
    <inertial>
      <origin xyz="0.040231 0.0044807 -0.035335" rpy="0 0 0" />
      <mass value="0.11714" />
      <inertia ixx="0.00019" ixy="-0.00002" ixz="-0.00009" iyy="0.00023" iyz="0.00002" izz="0.00014" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link4.STL" /></geometry>
      <material name=""><color rgba="0.79216 0.81961 0.92941 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link4.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint4" type="revolute">
    <origin xyz="0.245 0 -0.056" rpy="0 0 0" />
    <parent link="arm_link3" />
    <child link="arm_link4" />
    <axis xyz="0 1 0" />
    <limit lower="-1.6" upper="1.55" effort="15" velocity="5.5" />
  </joint>

  <link name="arm_link5">
    <inertial>
      <origin xyz="0.003612 -1.5455E-05 0.055214" rpy="0 0 0" />
      <mass value="0.63488" />
      <inertia ixx="0.00083" ixy="0.00000" ixz="0.00007" iyy="0.00082" iyz="0.00000" izz="0.00026" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link5.STL" /></geometry>
      <material name=""><color rgba="0.69804 0.69804 0.69804 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link5.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint5" type="revolute">
    <origin xyz="0.06775 0.0005 -0.0865" rpy="0 0 0" />
    <parent link="arm_link4" />
    <child link="arm_link5" />
    <axis xyz="0 0 1" />
    <limit lower="-1.57" upper="1.57" effort="10" velocity="5.0" />
  </joint>

  <link name="arm_link6">
    <inertial>
      <origin xyz="0.041697 2.4368E-05 0.00014464" rpy="0 0 0" />
      <mass value="0.44089" />
      <inertia ixx="0.00038" ixy="0.00000" ixz="0.00000" iyy="0.00028" iyz="0.00000" izz="0.00050" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link6.STL" /></geometry>
      <material name=""><color rgba="0.89804 0.91765 0.92941 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_link6.STL" /></geometry>
    </collision>
  </link>
  <joint name="arm_joint6" type="revolute">
    <origin xyz="0.02895 0 0.0865" rpy="-3.1416 0 0" />
    <parent link="arm_link5" />
    <child link="arm_link6" />
    <axis xyz="1 0 0" />
    <limit lower="-2.0" upper="2.0" effort="10" velocity="5.0" />
  </joint>

  <link name="arm_end_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1e-6" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="arm_end_fixed" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="arm_link6" />
    <child link="arm_end_link" />
  </joint>

  <link name="gripper_base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="1e-6" />
      <inertia ixx="1e-9" ixy="0" ixz="0" iyy="1e-9" iyz="0" izz="1e-9" />
    </inertial>
  </link>
  <joint name="gripper_base_fixed" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="arm_end_link" />
    <child link="gripper_base_link" />
  </joint>

  <link name="gripper_active_link">
    <inertial>
      <origin xyz="-0.00035522 0.0078277 0.0024201" rpy="0 0 0" />
      <mass value="0.064798" />
      <inertia ixx="0.00002" ixy="0.00000" ixz="0.00000" iyy="0.00003" iyz="0.00000" izz="0.00003" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_active_link.STL" /></geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_active_link.STL" /></geometry>
    </collision>
  </link>
  <joint name="gripper_active_joint" type="prismatic">
    <origin xyz="0.08657 -0.0249 -0.00024366" rpy="0 0 0" />
    <parent link="gripper_base_link" />
    <child link="gripper_active_link" />
    <axis xyz="0 -1 0" />
    <limit lower="0" upper="0.044" effort="10" velocity="0.5" />
  </joint>

  <link name="gripper_passive_link">
    <inertial>
      <origin xyz="-0.00035522 -0.007827 -0.0029883" rpy="0 0 0" />
      <mass value="0.064798" />
      <inertia ixx="0.00002" ixy="0.00000" ixz="0.00000" iyy="0.00003" iyz="0.00000" izz="0.00003" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_passive_link.STL" /></geometry>
      <material name=""><color rgba="1 1 1 1" /></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/gripper_passive_link.STL" /></geometry>
    </collision>
  </link>
  <joint name="gripper_passive_joint" type="prismatic">
    <origin xyz="0.08657 0.024896 -0.0002436" rpy="0 0 0" />
    <parent link="gripper_base_link" />
    <child link="gripper_passive_link" />
    <axis xyz="0 1 0" />
    <limit lower="0" upper="0.044" effort="10" velocity="0.5" />
    <mimic joint="gripper_active_joint" multiplier="1" offset="0" />
  </joint>

</robot>
