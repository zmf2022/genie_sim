<?xml version="1.0"?>
<!--
  ARX AC one (dual-arm) robot description.

  Adapted from src/external/ARX_Model/AC one/URDF/AC one/acone/urdf/acone.urdf
  with mesh paths rewritten to
  package://genie_sim_robot_model/robots/arx/acone/meshes/.

  Conventions (diverging from the SolidWorks export):
    - Links/joints renamed from left_*/right_*(11..18) to arm_l_*(1..8) /
      arm_r_*(1..8) so both arms share a single 1..8 numbering and the
      prefix is the only side disambiguator.
    - Joint limits, efforts and velocities aligned with the ARX X5 SDK
      (RobotConfigFactory.get_config('X5')). Both arms are mechanically
      the same 6-DOF X5 arm.
    - Parallel gripper: joint8 mimics joint7 with multiplier=1 so each
      gripper is driven by a single DOF.
    - After arm_*_link6: arm_*_end_link and gripper_*_base_link (identity
      fixed joints) so camera paths like /G2/gripper_*_base_link/... match
      other robot descriptions.
-->
<robot name="acone"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:property name="mesh_dir" value="package://genie_sim_robot_model/robots/arx/acone/meshes" />

  <!-- base_link is intentionally an empty link so it can serve as the KDL
       root: kdl_parser rejects a root link that carries inertia. The
       visual / collision / inertial payload is moved to base_link_inertia,
       a child of base_link via an identity-transform fixed joint. Both
       arm chains (arm_l_joint1, arm_r_joint1, ...) still hang off
       base_link, so no downstream link/joint names change.

       The 1mm guide-sphere <visual> below flips the Isaac Sim 6.0
       URDF→USD converter's is_ghost_link check to False so it authors
       body0=parent_link on every joint. See
       genie_sim_robot_model/AGENTS.md → "Non-ghost root link pattern". -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.001"/></geometry>
    </visual>
  </link>
  <link name="base_link_inertia">
    <inertial>
      <origin xyz="0.0040185 3.8157E-05 -0.024465" rpy="0 0 0" />
      <mass value="5.6137" />
      <inertia ixx="0.21931" ixy="0.00000" ixz="-0.00199" iyy="0.02598" iyz="0.00000" izz="0.20840" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/base_link.obj" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/base_link.obj" /></geometry>
    </collision>
  </link>
  <joint name="base_link-base_link_inertia" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="base_link_inertia" />
  </joint>

  <!-- ============================ LEFT ARM ============================ -->

  <link name="arm_l_link1">
    <inertial>
      <origin xyz="0.0054231 -0.0080289 0.017086" rpy="0 0 0" />
      <mass value="0.066982" />
      <inertia ixx="0.00008" ixy="0.00000" ixz="-0.00001" iyy="0.00003" iyz="0.00000" izz="0.00008" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_l_link1.obj" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_l_link1.obj" /></geometry>
    </collision>
  </link>
  <joint name="arm_l_joint1" type="revolute">
    <origin xyz="-0.01602 0.25 0.0215" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="arm_l_link1" />
    <axis xyz="0 0 1" />
    <limit lower="-3.14159" upper="3.14159" effort="30" velocity="5.0" />
  </joint>

  <link name="arm_l_link2">
    <inertial>
      <origin xyz="-0.13234 -0.0040166 0.00010941" rpy="0 0 0" />
      <mass value="1.1068" />
      <inertia ixx="0.00054" ixy="0.00000" ixz="0.00004" iyy="0.01653" iyz="0.00000" izz="0.01655" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_l_link2.obj" /></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry><mesh filename="${mesh_dir}/arm_l_link2.obj" /></geometry>
