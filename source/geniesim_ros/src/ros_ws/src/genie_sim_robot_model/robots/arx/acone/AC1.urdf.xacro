  </link>
  <joint name="arm_l_joint2" type="revolute">
    <origin xyz="0.02 0 0.04" rpy="0 0 0" />
    <parent link="arm_l_link1" />
    <child link="arm_l_link2" />
    <axis xyz="0 1 0" />
    <limit lower="-0.05" upper="3.5" effort="40" velocity="5.0" />
  </joint>

  <link name="arm_l_link3">
    <inertial>
      <origin xyz="0.18544 -0.00071369 0.051628" rpy="0 0 0" />
