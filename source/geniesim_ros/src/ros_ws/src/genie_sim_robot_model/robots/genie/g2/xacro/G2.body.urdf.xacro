<?xml version="1.0"?>
<!--
  G2 body (T2 variant) xacro macro.

  Provides base_link, body_link1-5, arm_base_link, and head_link1-3.
-->
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="body"
    params="arm_base_link collision_type mesh_dir app">
    <!-- Base -->
    <link name="base_link">

      <!--
        Inertia is expressed in its principal frame: <origin rpy> rotates
        the link frame into the principal frame, <inertia> is diagonal.
        Equivalent to the URDF full-tensor form; matches USD PhysicsMassAPI
        (diagonalInertia + principalAxes). Values are computed from the
        link's visual mesh under uniform density (rho = mass / volume);
        mass is taken from operator/CAD calibration and preserved.
      -->
      <inertial>
        <origin xyz="0.0 0.0 0.15" rpy="0 0 0" />
        <mass value="80.0" />
        <inertia ixx="3.1199677" iyy="3.5089187" izz="5.2989372" ixy="0" ixz="0" iyz="0" />
      </inertial>

      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/base_link.dae" />
        </geometry>
      </visual>

      <xacro:if value="${collision_type == 'visual'}">
        <collision name="base_link_visual_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/G2/base_link.STL" />
          </geometry>
        </collision>
      </xacro:if>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="base_link_coarse_0">
          <geometry>
            <box size="0.62673163 0.17409083 0.3258258" />
          </geometry>
          <origin xyz="0.011247277 -0.23094544 0.16291195" rpy="0.0 -0.0 0.0" />
        </collision>
        <collision name="base_link_coarse_1">
          <geometry>
            <box size="0.62667394 0.18714839 0.3258258" />
          </geometry>
          <origin xyz="0.011277318 0.23441666 0.16291195" rpy="0.0 -0.0 0.0" />
        </collision>
        <collision name="base_link_coarse_2">
          <geometry>
            <box size="0.6246023 0.23870158 0.06967827" />
          </geometry>
          <origin xyz="0.01230073 -0.01307106 0.11483914" rpy="0.0 -0.0 0.0" />
        </collision>
        <collision name="base_link_coarse_3">
          <geometry>
            <mesh filename="${mesh_dir}/G2/convex/base_link_1.STL" />
          </geometry>
        </collision>
        <collision name="base_link_coarse_4">
          <geometry>
            <mesh filename="${mesh_dir}/G2/convex/base_link_2.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="base_link_coarse_3" />
          <convex name="base_link_coarse_4" />
        </collision_checking>
      </xacro:if>
    </link>

    <link name="body_link1">
      <inertial>
        <origin xyz="0.0 0.0 0.175561673292876" rpy="0 0 0" />
        <mass value="10.0" />
        <inertia ixx="0.25937819" iyy="0.24426878" izz="0.039095076" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/body_link1.dae" />
        </geometry>
      </visual>
      <collision name="Cylinder">
        <origin xyz="0.0 0.0 0.0" rpy="1.570796 -0.0 0.0" />
        <geometry>
          <cylinder radius="0.089146" length="0.153391" />
        </geometry>
      </collision>
      <collision name="Cylinder.001">
        <origin xyz="0.0 0.0 0.360000" rpy="1.570796 -0.0 0.0" />
        <geometry>
          <cylinder radius="0.089146" length="0.153391" />
        </geometry>
      </collision>
      <collision name="Cube">
        <origin xyz="-0.024457 0.0 0.180000" rpy="0.0 0.0 0.0" />
        <geometry>
          <box size="0.085594 0.176618 0.351288" />
        </geometry>
      </collision>
      <collision name="Cube.001">
        <origin xyz="-0.009824 0.075429 0.180136" rpy="0.0 0.0 0.0" />
        <geometry>
          <box size="0.112587 0.027062 0.240828" />
        </geometry>
      </collision>
      <collision name="Cube.002">
        <origin xyz="-0.009824 -0.075429 0.180136" rpy="0.0 0.0 0.0" />
        <geometry>
          <box size="0.112587 0.027062 0.240828" />
        </geometry>
      </collision>
    </link>
    <joint name="idx01_body_joint1" type="revolute">
      <origin xyz="0.102 0 0.144" rpy="0 0 0" />
      <parent link="base_link" />
      <child link="body_link1" />
      <axis xyz="0 1 0" />
      <limit lower="-1.0822" upper="0.0001" effort="50" velocity="1.21" />
      <drive stiffness="100000" damping="1000" />
    </joint>

    <link name="body_link2">
      <inertial>
        <origin xyz="0.0 0.0 0.185408475115362" rpy="0 0 0" />
        <mass value="12.4" />
        <inertia ixx="0.36085406" iyy="0.25211292" izz="0.1476247" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/body_link2.dae" />
        </geometry>
      </visual>
      <collision name="body_link2_convex_0">
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/body_link2.STL" />
        </geometry>
      </collision>
      <collision_checking>
        <convex name="body_link2_convex_0" />
      </collision_checking>
    </link>
    <joint name="idx02_body_joint2" type="revolute">
      <origin xyz="0 0 0.36" rpy="0 0 0" />
      <parent link="body_link1" />
      <child link="body_link2" />
      <axis xyz="0 1 0" />
      <limit lower="-0.0001" upper="2.653" effort="50" velocity="1.21" />
      <drive stiffness="100000" damping="1000" />
    </joint>

    <link name="body_link3">
      <inertial>
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0" />
        <mass value="7.3" />
        <inertia ixx="0.029582642" iyy="0.027682651" izz="0.034064241" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/body_link3.dae" />
        </geometry>
      </visual>
      <collision name="body_link3_convex_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/body_link3.STL" />
        </geometry>
      </collision>
      <collision_checking>
        <convex name="body_link3_convex_0" />
      </collision_checking>
    </link>
    <joint name="idx03_body_joint3" type="revolute">
      <origin xyz="0 0 0.38" rpy="0 0 0" />
      <parent link="body_link2" />
      <child link="body_link3" />
      <axis xyz="0 1 0" />
      <limit lower="-1.907" upper="1.039" effort="50" velocity="1.21" />
      <drive stiffness="100000" damping="1000" />
    </joint>

    <link name="body_link4">
      <inertial>
        <origin xyz="-0.0714497732220123 0.0 0.0300405432603843"
          rpy="-5.500936e-06 -0.66395993 -2.2512849e-06" />
        <mass value="6.25" />
        <inertia ixx="0.004042693" iyy="0.10648367" izz="0.12366844" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/body_link4.dae" />
        </geometry>
      </visual>
      <collision name="body_link4_convex_1">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/body_link4_1.STL" />
        </geometry>
      </collision>
      <collision name="body_link4_convex_2">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/body_link4_2.STL" />
        </geometry>
      </collision>
      <collision name="body_link4_convex_3">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/body_link4_3.STL" />
        </geometry>
      </collision>
      <collision_checking>
        <convex name="body_link4_convex_1" />
        <convex name="body_link4_convex_2" />
        <convex name="body_link4_convex_3" />
      </collision_checking>
    </link>
    <joint name="idx04_body_joint4" type="revolute">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="body_link3" />
      <child link="body_link4" />
      <axis xyz="1 0 0" />
      <limit lower="-0.4364" upper="0.4364" effort="50" velocity="1.21" />
      <drive stiffness="100000" damping="1000" />
    </joint>

    <link name="body_link5">
      <inertial>
        <origin xyz="-0.0244423519676249 0.0 0.136945087391502" rpy="0 0 0" />
        <mass value="7.9" />
        <inertia ixx="0.24990702" iyy="0.23534933" izz="0.071565537" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/body_link5.dae" />
        </geometry>
      </visual>
      <collision name="body_link5_convex_0">
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/body_link5.STL" />
        </geometry>
      </collision>
      <collision_checking>
        <convex name="body_link5_convex_0" />
      </collision_checking>
    </link>
    <joint name="idx05_body_joint5" type="revolute">
      <origin xyz="0 0 0.149" rpy="0 0 0" />
      <parent link="body_link4" />
      <child link="body_link5" />
      <axis xyz="0 0 1" />
      <limit lower="-3.0456" upper="3.0456" effort="50" velocity="1.21" />
      <drive stiffness="100000" damping="1000" />
    </joint>

    <!-- Arm mount -->
    <link name="${arm_base_link}">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.001" />
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0" />
      </inertial>
    </link>
    <joint name="idx20_arm_base_joint" type="fixed">
      <origin rpy="-${PI_2} 0 0" xyz="0.0 0.0 0.3085" />
      <parent link="body_link5" />
      <child link="${arm_base_link}" />
      <axis xyz="0 0 0" />
    </joint>

    <!-- Head -->
    <link name="head_base_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.001" />
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0" />
      </inertial>
    </link>
    <joint name="idx10_head_base_joint" type="fixed">
      <origin rpy="0 0 0" xyz="-0.013 0 0.496" />
      <parent link="body_link5" />
      <child link="head_base_link" />
      <axis xyz="0 0 0" />
    </joint>

    <link name="head_link1">
      <inertial>
        <origin xyz="0.0 0.0 -0.0288855031850013" rpy="0 0 0" />
        <mass value="0.245638470524919" />
        <inertia ixx="0.00090246038" iyy="0.00084988987" izz="4.8123345e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/head_link1.dae" />
        </geometry>
      </visual>
    </link>
    <joint name="idx11_head_joint1" type="revolute">
      <origin xyz="-0.013 0 0.496" rpy="0 0 0" />
      <parent link="body_link5" />
      <child link="head_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-0.781" upper="0.781" effort="50" velocity="2.5" />
      <drive stiffness="1000" damping="20" />
    </joint>

    <link name="head_link2">
      <inertial>
        <origin xyz="-0.0363590807062005 0.0 0.0" rpy="0 0 0" />
        <mass value="0.0944986936701784" />
        <inertia ixx="3.5109823e-05" iyy="5.3548035e-05" izz="5.0428732e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/head_link2.dae" />
        </geometry>
      </visual>
    </link>
    <joint name="idx12_head_joint2" type="revolute">
      <origin xyz="0.03335 0 0.07" rpy="0 0 0" />
      <parent link="head_link1" />
      <child link="head_link2" />
      <axis xyz="1 0 0" />
      <limit lower="-0.151" upper="0.151" effort="50" velocity="2.5" />
      <drive stiffness="1000" damping="20" />
    </joint>

    <link name="head_link3">
      <inertial>
        <origin xyz="-0.00327292724863273 0.0 0.0163618254217082"
          rpy="-0.00018539305 0.38563878 -0.00095255121" />
        <mass value="2.5" />
        <inertia ixx="0.017589528" iyy="0.01422525" izz="0.010634233" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/head_link3.dae" />
        </geometry>
      </visual>
      <collision name="head_link3_convex_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/convex/head_link3.STL" />
        </geometry>
      </collision>
      <collision_checking>
        <convex name="head_link3_convex_0" />
      </collision_checking>
    </link>
    <joint name="idx13_head_joint3" type="revolute">
      <origin xyz="-0.03035 0 0" rpy="0 0 0" />
      <parent link="head_link2" />
      <child link="head_link3" />
      <axis xyz="0 1 0" />
      <limit lower="-0.0181" upper="0.5231" effort="50" velocity="2.5" />
      <drive stiffness="1000" damping="20" />
    </joint>

  </xacro:macro>
</robot>
