<?xml version="1.0"?>
<!-- TODO: collision meshes will be replaced with manually converted STL colliders -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    Omnipicker gripper xacro macro.

    Single `gripper` macro covers both sides.
    Pass side="l" for the left gripper, side="r" for the right gripper.
    Output link/joint names are gripper_l_* / gripper_r_* accordingly.

    idx offsets (base = 30 for l, 70 for r):
      +0   camera joint
      +1   inner_joint1  (driven)
      +2   inner_joint3
      +3   inner_joint4
      +9   inner_joint0
      +11  outer_joint1
      +12  outer_joint3
      +13  outer_joint4
      +19  outer_joint0
      +21  base_joint
      (+22 center_joint was removed: it carried a mass=0.001 helper
       body whose only role was to expose a TCP / grasp frame name
       to downstream planners; we now leave TCP frame management to
       the consumer.  See git history for the removal commit.)
      +23  loop outer_joint2
      +24  loop inner_joint2
  -->
  <xacro:macro
    name="gripper"
    params="side parent_link xyz_offset rpy_offset collision_type mesh_dir app">

    <xacro:property name="_b" value="${30 if side == 'l' else 70}" />

    <!-- Camera Link -->
    <link name="gripper_${side}_camera_link">
      <inertial>
        <origin xyz="0.012045 0.074409 0.04124" rpy="0.62349609 0.053350496 0.56306146" />
        <mass value="0.22805" />
        <inertia ixx="0.0003513493" iyy="0.0028770469" izz="0.0031536848" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/camera_link.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_camera_link_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/camera_link.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_camera_link_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <xacro:if value="${side == 'l'}">
      <joint name="idx${_b}_gripper_${side}_camera_joint" type="fixed">
        <origin xyz="0 0 0.0" rpy="${rpy_offset}" />
        <parent link="${parent_link}" />
        <child link="gripper_${side}_camera_link" />
        <axis xyz="0 0 0" />
      </joint>
    </xacro:if>
    <xacro:if value="${side == 'r'}">
      <joint name="idx${_b}_gripper_${side}_camera_joint" type="fixed">
        <origin xyz="0 0 0"
          rpy="${rpy_offset.split()[0]} ${rpy_offset.split()[1]} -${rpy_offset.split()[2]}" />
        <parent link="${parent_link}" />
        <child link="gripper_${side}_camera_link" />
        <axis xyz="0 0 0" />
      </joint>
    </xacro:if>

    <!-- Gripper Base Connector -->
    <joint name="idx${_b+21}_gripper_${side}_base_joint" type="fixed">
      <origin xyz="${xyz_offset}" rpy="${rpy_offset}" />
      <parent link="${parent_link}" />
      <child link="gripper_${side}_base_link" />
      <axis xyz="0 0 0" />
    </joint>

    <!-- (Gripper Center Link removed.)  Was a fixed-joint helper body
         with mass=0.001 used purely as a TCP / grasp frame for
         downstream planners.  Removed because it added 1 inertia-bearing
         body to mjwarp's body list per side while contributing nothing
         to the physics.  Downstream code (data_collection / curobo /
         benchmark) is expected to use a different TCP frame
         (``gripper_${side}_base_link`` is the natural fallback) and
         apply any z-offset on its own. -->

    <!-- Gripper Base -->
    <link name="gripper_${side}_base_link">
      <inertial>
        <origin xyz="-0.00013356 1.5301e-05 0.03322" rpy="0 0 0" />
        <mass value="0.23588" />
        <inertia ixx="0.00023759547" iyy="0.00020118956" izz="0.0001405122" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/base_link.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_base_link_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/base_link.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_base_link_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>

    <!-- Inner Chain: link1 → link3 → link4 → link2 -->
    <link name="gripper_${side}_inner_link1">
      <inertial>
        <origin xyz="0.0094685 0.0068806 6.5437e-05" rpy="0.01980138 -0.03290509 0.39448494" />
        <mass value="0.025428" />
        <inertia ixx="9.1720834e-06" iyy="3.8334008e-06" izz="1.0471027e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/inner_link1.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_inner_link1_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/inner_link1.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_inner_link1_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+1}_gripper_${side}_inner_joint1" type="revolute">
      <origin xyz="0 -0.0195 0.0565" rpy="${pi-2.9951} -${PI_2} -0.15964" />
      <parent link="gripper_${side}_base_link" />
      <child link="gripper_${side}_inner_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-${radians(45)}" upper="0" effort="10" velocity="10" />
      <drive stiffness="1000" damping="10" />
    </joint>

    <link name="gripper_${side}_inner_link3">
      <inertial>
        <origin xyz="0.0088027 -0.007035 1.6424e-05" rpy="-0.0066453898 0.00010459755 -0.71301206" />
        <mass value="0.0040132" />
        <inertia ixx="7.9130353e-08" iyy="3.8423887e-07" izz="3.6185602e-07" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/inner_link3.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_inner_link3_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/inner_link3.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_inner_link3_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+2}_gripper_${side}_inner_joint3" type="revolute">
      <origin xyz="0.030852 -0.018551 0" rpy="${PI} 0 0" />
      <parent link="gripper_${side}_inner_link1" />
      <child link="gripper_${side}_inner_link3" />
      <axis xyz="0 0 1" />
      <limit lower="-2" upper="2" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="0.1" offset="0" />
    </joint>

    <link name="gripper_${side}_inner_link4">
      <inertial>
        <origin xyz="0.012508 -0.0079729 9.4339e-05" rpy="-0.027250149 0.0062313518 -0.2256907" />
        <mass value="0.018029" />
        <inertia ixx="1.3444465e-06" iyy="4.2280185e-06" izz="3.9817261e-06" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/inner_link4.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_inner_link4_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/inner_link4.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_inner_link4_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+3}_gripper_${side}_inner_joint4" type="revolute">
      <origin xyz="0.018118 -0.01574 0" rpy="0 0 0" />
      <parent link="gripper_${side}_inner_link3" />
      <child link="gripper_${side}_inner_link4" />
      <axis xyz="0 0 1" />
      <limit lower="-2" upper="2" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="0.25" offset="0" />
    </joint>

    <link name="gripper_${side}_inner_link2">
      <inertial>
        <origin xyz="0.014869 -0.0036066 0.00029307" rpy="0.00083638041 -0.0068908483 -0.3308201" />
        <mass value="0.022591" />
        <inertia ixx="4.8113168e-06" iyy="2.9805385e-05" izz="2.5403463e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/inner_link2.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_inner_link2_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/inner_link2.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_inner_link2_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+9}_gripper_${side}_inner_joint0" type="revolute">
      <origin xyz="0.0 -0.01 0.0" rpy="0 0 0" />
      <parent link="gripper_${side}_inner_link4" />
      <child link="gripper_${side}_inner_link2" />
      <axis xyz="0 0 1" />
      <limit lower="-2" upper="2" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-0.7" offset="0" />
    </joint>

    <!-- Outer Chain: link1 → link3 → link4 → link2 -->
    <link name="gripper_${side}_outer_link1">
      <inertial>
        <origin xyz="0.0095051 -0.0068479 6.8268e-05" rpy="-0.0059487609 -0.0030989317 -0.39697444" />
        <mass value="0.025428" />
        <inertia ixx="9.1470314e-06" iyy="3.801901e-06" izz="1.0413078e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/outer_link1.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_outer_link1_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/outer_link1.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_outer_link1_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+11}_gripper_${side}_outer_joint1" type="revolute">
      <origin xyz="0 0.0195 0.0565" rpy="${PI-2.9951} -${PI_2} -0.15964" />
      <parent link="gripper_${side}_base_link" />
      <child link="gripper_${side}_outer_link1" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="${radians(45)}" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-1" offset="0" />
    </joint>

    <link name="gripper_${side}_outer_link3">
      <inertial>
        <origin xyz="0.0088027 0.007035 -1.6424e-05" rpy="-0.0066453898 -0.00010459755 0.71301206" />
        <mass value="0.0040132" />
        <inertia ixx="7.9130353e-08" iyy="3.8423887e-07" izz="3.6185602e-07" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/outer_link3.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_outer_link3_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/outer_link3.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_outer_link3_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+12}_gripper_${side}_outer_joint3" type="revolute">
      <origin xyz="0.030852 0.018551 0" rpy="${PI} 0 0" />
      <parent link="gripper_${side}_outer_link1" />
      <child link="gripper_${side}_outer_link3" />
      <axis xyz="0 0 1" />
      <limit lower="-2" upper="2" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="0.1" offset="0" />
    </joint>

    <link name="gripper_${side}_outer_link4">
      <inertial>
        <origin xyz="0.016206 0.0094593 4.7668e-05" rpy="0.002289545 -0.012517293 -0.22747111" />
        <mass value="0.035835" />
        <inertia ixx="1.7278545e-05" iyy="1.1480484e-05" izz="5.8972392e-06" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/outer_link4.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_outer_link4_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/outer_link4.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_outer_link4_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+13}_gripper_${side}_outer_joint4" type="revolute">
      <origin xyz="0.018118 0.01574 0" rpy="0 0 0" />
      <parent link="gripper_${side}_outer_link3" />
      <child link="gripper_${side}_outer_link4" />
      <axis xyz="0 0 1" />
      <limit lower="-2" upper="2" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-0.25" offset="0" />
    </joint>

    <link name="gripper_${side}_outer_link2">
      <inertial>
        <origin xyz="0.016268 0.0040555 0.00030323" rpy="0.0016738527 -0.011168778 0.33285961" />
        <mass value="0.025142" />
        <inertia ixx="6.6962753e-06" iyy="3.5571481e-05" izz="2.9443722e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/omnipicker/outer_link2.dae" />
        </geometry>
      </visual>
      <xacro:if value="${collision_type == 'fine'}">
        <collision name="gripper_${side}_outer_link2_convex_0">
          <origin xyz="0 0 0" rpy="0 0 0" />
          <geometry>
            <mesh filename="${mesh_dir}/gripper/omnipicker/convex/outer_link2.STL" />
          </geometry>
        </collision>
        <collision_checking>
          <convex name="gripper_${side}_outer_link2_convex_0" />
        </collision_checking>
      </xacro:if>
    </link>
    <joint name="idx${_b+19}_gripper_${side}_outer_joint0" type="revolute">
      <origin xyz="0.0 0.01 0.0" rpy="0 0 0" />
      <parent link="gripper_${side}_outer_link4" />
      <child link="gripper_${side}_outer_link2" />
      <axis xyz="0 0 1" />
      <limit lower="-2" upper="2" effort="10" velocity="10" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="0.7" offset="0" />
    </joint>

    <!-- Closed-loop kinematic constraints -->
    <loop_joint name="idx${_b+23}_gripper_${side}_outer_joint2" type="spherical">
      <link1 link="gripper_${side}_base_link" xyz="0 0.012 0.105" rpy="-2.9951 -${PI_2} -0.15964" />
      <link2 link="gripper_${side}_outer_link2" xyz="0 0 0" rpy="0 0 0" />
      <axis xyz="0 0 1" />
    </loop_joint>
    <loop_joint name="idx${_b+24}_gripper_${side}_inner_joint2" type="spherical">
      <link1 link="gripper_${side}_base_link" xyz="0 -0.012 0.105" rpy="-2.9951 -${PI_2} -0.15964" />
      <link2 link="gripper_${side}_inner_link2" xyz="0 0 0" rpy="0 0 0" />
      <axis xyz="0 0 1" />
    </loop_joint>

  </xacro:macro>
</robot>
