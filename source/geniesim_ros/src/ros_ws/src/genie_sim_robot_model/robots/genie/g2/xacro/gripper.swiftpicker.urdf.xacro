<?xml version="1.0"?>
<!-- TODO: collision meshes will be replaced with manually converted STL colliders -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    SwiftPicker gripper xacro macro.

    Single `gripper` macro covers both sides.
    Pass side="l" for the left gripper, side="r" for the right gripper.
    Output link/joint names are gripper_l_* / gripper_r_* accordingly.

    idx offsets (base = 30 for l, 70 for r):
      +0  camera joint
      +1  inner_joint1  (driven)
      +2  outer_joint1
      +3  left_support_joint
      +4  inner_joint2
      +5  outer_joint2
      +6  right_support_joint
      +21 base_joint
      (+22 center_joint was removed: it carried a mass=0.001 helper
       body whose only role was to expose a TCP / grasp frame name
       to downstream planners; we now leave TCP frame management to
       the consumer.  See git history for the removal commit.)
  -->
  <xacro:macro
    name="gripper"
    params="side parent_link xyz_offset rpy_offset collision_type mesh_dir app">

    <xacro:property name="_b" value="${30 if side == 'l' else 70}" />

    <!-- Camera Link -->
    <link name="gripper_${side}_camera_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.001" />
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/camera_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_camera_link_collision_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/camera_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b}_gripper_${side}_camera_joint" type="fixed">
      <origin xyz="0 0 0.0" rpy="${rpy_offset}" />
      <parent link="${parent_link}" />
      <child link="gripper_${side}_camera_link" />
      <axis xyz="0 0 0" />
    </joint>

    <!-- Gripper Base Connector -->
    <joint name="idx${_b+21}_gripper_${side}_base_joint" type="fixed">
      <origin xyz="${xyz_offset}" rpy="${rpy_offset}" />
      <parent link="${parent_link}" />
      <child link="gripper_${side}_base_link" />
      <axis xyz="0 0 0" />
    </joint>

    <!-- (Gripper Center Link removed.)  Was a fixed-joint helper body
         with mass=0.001 used purely as a TCP / grasp frame for
         downstream planners.  Removed because it added 1 inertia-bearing
         body to mjwarp's body list per side while contributing nothing
         to the physics.  Downstream code (data_collection / curobo /
         benchmark) is expected to use a different TCP frame
         (``gripper_${side}_base_link`` is the natural fallback) and
         apply any z-offset on its own. -->

    <!-- Gripper Base -->
    <link name="gripper_${side}_base_link">
      <inertial>
        <origin xyz="3.84872289645122e-06 -4.41448135187968e-05 0.0553867866771657"
          rpy="-0.001472075 -0.12786537 0.013352066" />
        <mass value="0.953455976099042" />
        <inertia ixx="0.0021559171" iyy="0.0020303297" izz="0.00072910428" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/base_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_base_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/base_link.STL" />
        </geometry>
      </collision>
    </link>

    <!-- Left Inner Finger -->
    <link name="gripper_${side}_left_inner_link">
      <inertial>
        <origin xyz="0.0202604071221829 0.0187577877878552 2.21631403129407e-14"
          rpy="-5.2560057e-05 -9.0648445e-05 0.74689495" />
        <mass value="0.0309052898336314" />
        <inertia ixx="1.7493977e-06" iyy="1.0327289e-05" izz="9.2048593e-06" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/left_inner_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_left_inner_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/left_inner_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b+1}_gripper_${side}_inner_joint1" type="revolute">
      <origin xyz="0.016 0 0.121" rpy="${PI_2} 0 0" />
      <parent link="gripper_${side}_base_link" />
      <child link="gripper_${side}_left_inner_link" />
      <axis xyz="0 0 -1" />
      <!-- master joint of the parallel-jaw mimic chain.  Newton's add_usd
           reads limit effort into joint_effort_limit which mjwarp
           bakes as actfrcrange (and actfrclimited true) on the
           joint.  That hard-caps the total actuator force on the
           master (P + D combined), regardless of what the runtime
           PD demands.

           Old value was effort=5 matching the reference G2 MJCF
           gainprm.  At runtime kit/stage.py sets master kp=10000
           via params.yaml drive.gripper.master_stiffness, which
           means any error of more than 5/10000 = 0.0005 rad (0.03
           degrees) saturates the cap and the gripper drifts under
           inertial perturbation from arm motion.  Quantified by
           test_robot_xml_dynamic.py cross-impact-mode sweep: at
           the prior effort=5, sweeping arm_l_joint3 by 0.5 rad
           coupled into gripper_l_outer_joint2 with coupling 0.16
           and a drift per cycle of about 0.02 rad — the visible
           "does not hold position when arms move" symptom.

           effort=50 gives the master 10x more force authority
           without changing the URDF mass, inertia, or mimic
           topology.  At kp=10000 the saturation point moves to
           0.005 rad (0.3 degrees), comfortably above the
           inertial-coupling error from a 0.5 rad / 0.5 Hz arm
           sweep.

           dynamics damping/friction propagate to joint_target_kd
           and joint_friction respectively; the gripper class's
           damping=0.05 is authored by
           assemble_robot._apply_mimic_joint_overlay as mjc:damping
           (the URDF damping=0 stays since the dynamics block also
           feeds drive kd which the runtime overrides with
           params.yaml master_damping=10). -->
      <limit lower="-0.91" upper="0" effort="50" velocity="2" />
      <!-- Fix A (2026-06): damping bumped 0 -> 0.5 N*m*s/rad on every
           gripper joint (master + 5 mimics).  Without joint damping,
           the low-Iyy fingertip pad (support_link Iyy=4.2e-6, see
           Fix B) springs back from contact and the resulting force-
           modulation between substeps lets grasped round objects
           (hanger bar) spin in the jaw.  0.5 is small relative to
           the master's PD damping (kd=200) so it doesn't slow the
           close, but it absorbs the per-substep oscillation. -->
      <dynamics damping="0.5" friction="0.01" />
    </joint>

    <!-- Left Outer Finger -->
    <link name="gripper_${side}_left_outer_link">
      <inertial>
        <origin xyz="0.0202604071221892 0.0187577877882694 2.20960470526592e-14"
          rpy="-5.2560057e-05 -9.0648445e-05 0.74689495" />
        <mass value="0.0309052898336316" />
        <inertia ixx="1.7493977e-06" iyy="1.0327289e-05" izz="9.2048593e-06" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/left_outer_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_left_outer_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/left_outer_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b+2}_gripper_${side}_outer_joint1" type="revolute">
      <origin xyz="0.030141 0 0.10415" rpy="${PI_2} 0 0" />
      <parent link="gripper_${side}_base_link" />
      <child link="gripper_${side}_left_outer_link" />
      <axis xyz="0 0 -1" />
      <limit lower="-0.91" upper="0" effort="10" velocity="2" />
      <dynamics damping="0.5" friction="0.01" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="1" offset="0" />
    </joint>

    <!-- Left Support Link -->
    <link name="gripper_${side}_left_support_link">
      <inertial>
        <origin xyz="-0.0177925864232372 0.0354308985297288 -3.45319167880073e-05"
          rpy="3.8703124e-06 -2.5701336e-05 0.29514787" />
        <mass value="0.0828693338705683" />
        <!-- Fix B (2026-06): Iyy bumped 4.20e-6 -> 2.00e-5 (5x).
             Y is the closing axis; the URDF-authored Iyy was 6.7x
             lower than Ixx/Izz because the support link is a thin
             pad oriented across the closing direction.  Under
             contact torque from a grasped round object (hanger bar)
             this low Iyy let the pad accelerate angularly 7x faster
             than about the orthogonal axes, releasing the object to
             spin.  The bump is a tuning fix, not strictly physical:
             we're pretending the rubber pad + linkage have more
             rotational inertia about the closing axis than the
             solid-body STL would imply. -->
        <inertia ixx="2.803687e-05" iyy="2.0e-05" izz="2.9771109e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/left_support_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_left_support_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/left_support_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b+3}_gripper_${side}_left_support_joint" type="revolute">
      <origin xyz="0.040359 0.037365 0" rpy="0 0 0" />
      <parent link="gripper_${side}_left_outer_link" />
      <child link="gripper_${side}_left_support_link" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.91" effort="10" velocity="2" />
      <dynamics damping="0.5" friction="0.01" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-1" offset="0" />
    </joint>

    <!-- Right Inner Finger -->
    <link name="gripper_${side}_right_inner_link">
      <inertial>
        <origin xyz="0.0202604071211299 0.0187577877883374 2.11370080968728e-14"
          rpy="-5.2560057e-05 -9.0648445e-05 0.74689495" />
        <mass value="0.0309052898336316" />
        <inertia ixx="1.7493977e-06" iyy="1.0327289e-05" izz="9.2048593e-06" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/right_inner_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_right_inner_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/right_inner_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b+4}_gripper_${side}_inner_joint2" type="revolute">
      <origin xyz="-0.016 0 0.121" rpy="${PI_2} 0 ${PI}" />
      <parent link="gripper_${side}_base_link" />
      <child link="gripper_${side}_right_inner_link" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="0.91" effort="10" velocity="2" />
      <dynamics damping="0.5" friction="0.01" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-1" offset="0" />
    </joint>

    <!-- Right Outer Finger -->
    <link name="gripper_${side}_right_outer_link">
      <inertial>
        <origin xyz="0.0202604071211989 0.0187577877891044 2.11409547592425e-14"
          rpy="-5.2560057e-05 -9.0648445e-05 0.74689495" />
        <mass value="0.0309052898336314" />
        <inertia ixx="1.7493977e-06" iyy="1.0327289e-05" izz="9.2048593e-06" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/right_outer_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_right_outer_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/right_outer_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b+5}_gripper_${side}_outer_joint2" type="revolute">
      <origin xyz="-0.030141 0 0.10415" rpy="${PI_2} 0 ${PI}" />
      <parent link="gripper_${side}_base_link" />
      <child link="gripper_${side}_right_outer_link" />
      <axis xyz="0 0 1" />
      <limit lower="0" upper="0.91" effort="10" velocity="2" />
      <dynamics damping="0.5" friction="0.01" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-1" offset="0" />
    </joint>

    <!-- Right Support Link -->
    <link name="gripper_${side}_right_support_link">
      <inertial>
        <origin xyz="-0.0177925878352495 0.0354308970643828 -2.81887513877937e-08"
          rpy="-6.7588312e-07 -4.2858103e-05 0.29514126" />
        <mass value="0.082869359674167" />
        <!-- Fix B mirror: Iyy bumped 4.20e-6 -> 2.00e-5.  Mirrors
             the left_support_link bump above (see comment there). -->
        <inertia ixx="2.8036899e-05" iyy="2.0e-05" izz="2.9771141e-05" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/right_support_link.dae" />
        </geometry>
        <material_override>
          <roughness>0.45</roughness>
          <metallic>0.0</metallic>
        </material_override>
      </visual>
      <collision name="gripper_${side}_right_support_link_visual_0">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/gripper/swiftpicker/right_support_link.STL" />
        </geometry>
      </collision>
    </link>
    <joint name="idx${_b+6}_gripper_${side}_right_support_joint" type="revolute">
      <origin xyz="0.040359 0.037365 0" rpy="0 0 0" />
      <parent link="gripper_${side}_right_outer_link" />
      <child link="gripper_${side}_right_support_link" />
      <axis xyz="0 0 -1" />
      <limit lower="0" upper="0.91" effort="10" velocity="2" />
      <dynamics damping="0.5" friction="0.01" />
      <mimic joint="idx${_b+1}_gripper_${side}_inner_joint1" multiplier="-1" offset="0" />
    </joint>

  </xacro:macro>
</robot>
