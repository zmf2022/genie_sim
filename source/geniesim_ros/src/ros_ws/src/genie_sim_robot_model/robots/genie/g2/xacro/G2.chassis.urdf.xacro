<?xml version="1.0"?>
<!--
  G2 chassis xacro macro.

  Provides the four-wheel mecanum chassis (chassis_link, 4x lwheel/rwheel linkages).

  Inertias are computed from each link's visual mesh under uniform density
  (rho = mass / volume), then expressed in principal frame: <origin rpy>
  rotates link frame into principal frame, <inertia> is diagonal. Equivalent
  to URDF full-tensor form; matches USD PhysicsMassAPI (diagonalInertia +
  principalAxes). Mass is preserved from operator/CAD calibration.
-->
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="chassis"
    params="collision_type mesh_dir app">

    <xacro:property name="PI" value="3.1415926535897931" />
    <xacro:property name="PI_2" value="1.5707963267948966" />

    <!-- Base Joint -->
    <joint name="idx100_chassis_base_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0" />
      <parent link="base_link" />
      <child link="chassis_link" />
    </joint>

    <!-- Chassis -->
    <link name="chassis_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <mass value="0.001" />
        <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0" />
      </inertial>
    </link>

    <!-- Left-front wheel -->
    <link name="chassis_lwheel_front_link1">
      <inertial>
        <origin xyz="4.8347e-05 -0.021386 -0.055149" rpy="-0.59060787 -0.00032074058 9.7568723e-05" />
        <mass value="0.59301" />
        <inertia ixx="0.0011622608" iyy="0.0010945563" izz="0.00027125101" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_lwheel_front_link1.dae" />
        </geometry>
      </visual>
    </link>
    <joint name="idx111_chassis_lwheel_front_joint1" type="revolute">
      <origin xyz="0.23 0.218 0.16675" rpy="0 0 0" />
      <parent link="chassis_link" />
      <child link="chassis_lwheel_front_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-2.97" upper="2.97" effort="15" velocity="4.08" />
    </joint>

    <link name="chassis_lwheel_front_link2">
      <inertial>
        <origin xyz="-2.3442e-06 -0.0013086 1.0892e-05" rpy="0 0 0" />
        <mass value="3.6283" />
        <inertia ixx="0.0053807877" iyy="0.0082877079" izz="0.00571362" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_lwheel_front_link2.dae" />
        </geometry>
      </visual>
      <collision name="chassis_lwheel_front_link2_cylinder">
        <origin xyz="0 0 0" rpy="${PI_2} 0 0" />
        <geometry>
          <cylinder radius="0.07" length="0.040" />
        </geometry>
      </collision>
    </link>
    <joint name="idx112_chassis_lwheel_front_joint2" type="continuous">
      <origin xyz="0 -5E-05 -0.13675" rpy="0 0 0" />
      <parent link="chassis_lwheel_front_link1" />
      <child link="chassis_lwheel_front_link2" />
      <axis xyz="0 1 0" />
      <limit lower="0" upper="0" effort="8" velocity="20.9" />
    </joint>

    <!-- Right-front wheel -->
    <link name="chassis_rwheel_front_link1">
      <inertial>
        <origin xyz="-4.8347e-05 0.021386 -0.055149" rpy="0.59060787 0.00032091139 9.7620683e-05" />
        <mass value="0.59301" />
        <inertia ixx="0.0011622608" iyy="0.0010945563" izz="0.000271251" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_rwheel_front_link1.dae" />
        </geometry>
      </visual>
    </link>
    <joint name="idx131_chassis_rwheel_front_joint1" type="revolute">
      <origin xyz="0.23 -0.218 0.16675" rpy="0 0 0" />
      <parent link="chassis_link" />
      <child link="chassis_rwheel_front_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-2.97" upper="2.97" effort="15" velocity="4.08" />
    </joint>

    <link name="chassis_rwheel_front_link2">
      <inertial>
        <origin xyz="2.3442e-06 0.0013086 1.0892e-05" rpy="0 0 0" />
        <mass value="3.6283" />
        <inertia ixx="0.0053807877" iyy="0.0082877079" izz="0.00571362" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_rwheel_front_link2.dae" />
        </geometry>
      </visual>
      <collision name="chassis_rwheel_front_link2_cylinder">
        <origin xyz="0 0 0" rpy="${PI_2} 0 0" />
        <geometry>
          <cylinder radius="0.07" length="0.040" />
        </geometry>
      </collision>
    </link>
    <joint name="idx132_chassis_rwheel_front_joint2" type="continuous">
      <origin xyz="0 5E-05 -0.13675" rpy="0 0 0" />
      <parent link="chassis_rwheel_front_link1" />
      <child link="chassis_rwheel_front_link2" />
      <axis xyz="0 1 0" />
      <limit lower="0" upper="0" effort="8" velocity="20.9" />
    </joint>

    <!-- Right-rear wheel -->
    <link name="chassis_rwheel_rear_link1">
      <inertial>
        <origin xyz="-4.8347e-05 0.021386 -0.055149" rpy="0.59060787 0.00032091139 9.7620683e-05" />
        <mass value="0.59301" />
        <inertia ixx="0.0011622608" iyy="0.0010945563" izz="0.000271251" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_rwheel_rear_link1.dae" />
        </geometry>
      </visual>
    </link>
    <joint name="idx141_chassis_rwheel_rear_joint1" type="revolute">
      <origin xyz="-0.23 -0.218 0.16675" rpy="0 0 0" />
      <parent link="chassis_link" />
      <child link="chassis_rwheel_rear_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-2.97" upper="2.97" effort="15" velocity="4.08" />
    </joint>

    <link name="chassis_rwheel_rear_link2">
      <inertial>
        <origin xyz="2.3442e-06 0.0013086 1.0892e-05" rpy="0 0 0" />
        <mass value="3.6283" />
        <inertia ixx="0.0053807877" iyy="0.0082877079" izz="0.00571362" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_rwheel_rear_link2.dae" />
        </geometry>
      </visual>
      <collision name="chassis_rwheel_rear_link2_cylinder">
        <origin xyz="0 0 0" rpy="${PI_2} 0 0" />
        <geometry>
          <cylinder radius="0.07" length="0.040" />
        </geometry>
      </collision>
    </link>
    <joint name="idx142_chassis_rwheel_rear_joint2" type="continuous">
      <origin xyz="0 5E-05 -0.13675" rpy="0 0 0" />
      <parent link="chassis_rwheel_rear_link1" />
      <child link="chassis_rwheel_rear_link2" />
      <axis xyz="0 1 0" />
      <limit lower="0" upper="0" effort="8" velocity="20.9" />
    </joint>

    <!-- Left-rear wheel -->
    <link name="chassis_lwheel_rear_link1">
      <inertial>
        <origin xyz="4.8347e-05 -0.021386 -0.055149" rpy="-0.59060787 -0.00032074058 9.7568723e-05" />
        <mass value="0.59301" />
        <inertia ixx="0.0011622608" iyy="0.0010945563" izz="0.00027125101" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_lwheel_rear_link1.dae" />
        </geometry>
      </visual>
    </link>
    <joint name="idx121_chassis_lwheel_rear_joint1" type="revolute">
      <origin xyz="-0.23 0.218 0.16675" rpy="0 0 0" />
      <parent link="chassis_link" />
      <child link="chassis_lwheel_rear_link1" />
      <axis xyz="0 0 1" />
      <limit lower="-2.97" upper="2.97" effort="15" velocity="4.08" />
    </joint>

    <link name="chassis_lwheel_rear_link2">
      <inertial>
        <origin xyz="-2.3442e-06 -0.0013086 1.0892e-05" rpy="0 0 0" />
        <mass value="3.6283" />
        <inertia ixx="0.0053807877" iyy="0.0082877079" izz="0.00571362" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="${mesh_dir}/G2/chassis_lwheel_rear_link2.dae" />
        </geometry>
      </visual>
      <collision name="chassis_lwheel_rear_link2_cylinder">
        <origin xyz="0 0 0" rpy="${PI_2} 0 0" />
        <geometry>
          <cylinder radius="0.07" length="0.040" />
        </geometry>
      </collision>
    </link>
    <joint name="idx122_chassis_lwheel_rear_joint2" type="continuous">
      <origin xyz="0 -5E-05 -0.13675" rpy="0 0 0" />
      <parent link="chassis_lwheel_rear_link1" />
      <child link="chassis_lwheel_rear_link2" />
      <axis xyz="0 1 0" />
      <limit lower="0" upper="0" effort="8" velocity="20.9" />
    </joint>

  </xacro:macro>
</robot>
