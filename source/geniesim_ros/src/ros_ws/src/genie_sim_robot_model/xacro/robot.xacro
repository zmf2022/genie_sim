<?xml version="1.0"?>
<!--
  Universal robot entry point.

  Usage (xacro CLI or launch-file):
    xacro robot.xacro robot_model:=agilex arm:=piper
    xacro robot.xacro robot_model:=agilex arm:=piper gripper:=no_gripper
    xacro robot.xacro robot_model:=agilex arm:=aloha
    xacro robot.xacro robot_model:=arx arm:=x5
    xacro robot.xacro robot_model:=genie arm:=crs  gripper:=omnipicker
    xacro robot.xacro robot_model:=genie arm:=crsB gripper:=swiftpicker
    xacro robot.xacro robot_model:=universal_robots arm:=ur5
    xacro robot.xacro robot_model:=urdf   urdf_package:=franka_description urdf_file:=robots/fr3.urdf

  Parameters:
    robot_model    - Robot family or model name.
                     Values: arx | agilex | franka | genie | universal_robots | urdf | xacro_file

  Model-specific parameters are forwarded as-is; each adapter
  xacro declares its own defaults. See xacro/providers/*.xacro.
-->
<robot name="robot"
  xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="robot_model" default="agilex" />

  <xacro:property name="robot_model" value="$(arg robot_model)" />

  <!-- ======================== arx (ARX robotics) ======================== -->
  <xacro:if value="${'arx' == robot_model}">
    <xacro:include filename="providers/arx.xacro" />
  </xacro:if>

  <!-- ======================== agilex (Agilex: Aloha, Piper) ======================== -->
  <xacro:if value="${'agilex' == robot_model}">
    <xacro:include filename="providers/agilex.xacro" />
  </xacro:if>

  <!-- ======================== franka (Franka Robotics) ======================== -->
  <xacro:if value="${'franka' == robot_model}">
    <xacro:include filename="providers/franka.xacro" />
  </xacro:if>

  <!-- ======================== genie (AgiBot Genie series, e.g. G2) ======================== -->
  <xacro:if value="${'genie' == robot_model}">
    <xacro:include filename="providers/genie.xacro" />
  </xacro:if>

  <!-- ======================== universal_robots (UR series) ======================== -->
  <xacro:if value="${'universal_robots' == robot_model}">
    <xacro:include filename="providers/universal_robots.xacro" />
  </xacro:if>

  <!-- ======================== generic urdf (any *_description package) ======================== -->
  <xacro:if value="${'urdf' == robot_model}">
    <xacro:include filename="providers/urdf.xacro" />
  </xacro:if>

  <!-- ======================== generic xacro file ======================== -->
  <xacro:if value="${'xacro_file' == robot_model}">
    <xacro:include filename="providers/xacro_file.xacro" />
  </xacro:if>

</robot>
